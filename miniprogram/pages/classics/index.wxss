/* pages/classics/index.wxss - 诗词典籍样式 v6.0 */

.classics-page { background: #FDF6E3; min-height: 100vh; }

/* ── 页头 ─────────────────────────────── */
.page-header {
  background: linear-gradient(160deg, #4A0E6B 0%, #6B2FA0 55%, #8B3FC0 100%);
  padding: 32rpx 30rpx 44rpx;
}
.header-title { display: block; font-size: 42rpx; font-weight: 700; color: #FFF8E7; letter-spacing: 4rpx; }
.header-sub { display: block; font-size: 24rpx; color: rgba(255,248,231,.6); margin-top: 8rpx; letter-spacing: 3rpx; }

/* ── 搜索栏 ─────────────────────────────── */
.search-bar {
  margin: -20rpx 24rpx 0;
  background: #FFFBF0;
  border-radius: 20rpx;
  padding: 12rpx 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(106,61,168,.15);
  border: 1rpx solid #D4B8F0;
}
.search-inner { display: flex; align-items: center; gap: 10rpx; }
.search-icon { font-size: 28rpx; flex-shrink: 0; }
.search-input { flex: 1; font-size: 26rpx; color: #2C1810; height: 56rpx; }
.search-placeholder { color: #B09070; font-size: 24rpx; }
.search-btn {
  background: linear-gradient(90deg, #6B2FA0, #8B3FC0);
  border-radius: 20rpx; padding: 8rpx 24rpx;
}
.search-btn-hover { opacity: 0.8 !important; }
.search-btn-text { font-size: 24rpx; color: #FFF8E7; font-weight: 500; }
.search-loading { padding: 8rpx 16rpx; }
.search-loading-text { font-size: 28rpx; color: #8C7B61; }

/* ── 搜索结果 ─────────────────────────────── */
.search-result-section {
  background: #FFFBF0;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  border: 1rpx solid #6B2FA0;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(106,61,168,.12);
}
.result-header {
  background: linear-gradient(90deg, #6B2FA0, #8B3FC0);
  padding: 16rpx 20rpx;
  display: flex; align-items: center; justify-content: space-between;
}
.result-title-row { display: flex; align-items: center; gap: 10rpx; }
.result-dot { width: 10rpx; height: 10rpx; background: #FFD97D; border-radius: 50%; }
.result-title { font-size: 26rpx; color: #FFF8E7; font-weight: 600; }
.result-actions { display: flex; gap: 12rpx; }
.action-btn {
  background: rgba(255,255,255,.2); border-radius: 20rpx;
  padding: 6rpx 16rpx; font-size: 22rpx; color: #FFF8E7;
}
.action-hover { background: rgba(255,255,255,.35) !important; }
.result-loading { display: flex; flex-direction: column; align-items: center; padding: 40rpx; gap: 16rpx; }
.ai-loading-icon { font-size: 56rpx; animation: swing 1.5s infinite; }
@keyframes swing { 0%,100% { transform: rotate(-8deg); } 50% { transform: rotate(8deg); } }
.ai-loading-text { font-size: 24rpx; color: #8C7B61; }
.result-body { padding: 24rpx; }
.seg-block { margin-bottom: 18rpx; }
.seg-label-row { display: flex; align-items: center; gap: 10rpx; margin-bottom: 8rpx; }
.seg-dot { width: 8rpx; height: 28rpx; background: linear-gradient(180deg, #8B3FC0, #6B2FA0); border-radius: 4rpx; }
.seg-label { font-size: 26rpx; font-weight: 600; color: #6B2FA0; }
.seg-content { font-size: 26rpx; color: #2C1810; line-height: 1.9; padding-left: 18rpx; white-space: pre-wrap; }

/* ── Tab ─────────────────────────────── */
.tabs-scroll { margin: 20rpx 0 0; padding: 0 24rpx; white-space: nowrap; }
.tabs-row { display: inline-flex; gap: 14rpx; padding-bottom: 8rpx; }
.tab-item {
  display: inline-flex; align-items: center; gap: 8rpx;
  background: #FFFBF0; border: 1rpx solid #D4B8F0;
  border-radius: 32rpx; padding: 12rpx 24rpx;
  white-space: nowrap;
}
.tab-hover { background: #F0E0FF !important; }
.tab-active {
  background: linear-gradient(135deg, #6B2FA0, #8B3FC0);
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(106,61,168,.25);
}
.tab-icon { font-size: 24rpx; }
.tab-name { font-size: 24rpx; color: #5A4030; }
.tab-active .tab-name { color: #FFF8E7; }

/* ── 精选推荐 ─────────────────────────────── */
.featured-section { margin-top: 20rpx; }
.featured-scroll { padding: 0 24rpx; white-space: nowrap; }
.featured-row { display: inline-flex; gap: 16rpx; padding-bottom: 8rpx; }
.featured-card {
  width: 280rpx; height: 200rpx;
  border-radius: 20rpx;
  padding: 20rpx;
  display: inline-flex; flex-direction: column; justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,.15);
  position: relative; overflow: hidden;
}
.featured-hover { opacity: 0.88 !important; transform: scale(.97); }
.featured-badge {
  position: absolute; top: 14rpx; right: 14rpx;
  background: rgba(255,255,255,.25); border-radius: 12rpx;
  padding: 3rpx 12rpx; font-size: 18rpx; color: #fff;
}
.featured-desc { font-size: 19rpx; color: rgba(255,255,255,.7); }
.featured-title { font-size: 36rpx; font-weight: 700; color: #fff; margin-top: 4rpx; }
.featured-author { font-size: 20rpx; color: rgba(255,255,255,.8); }
.featured-preview { font-size: 20rpx; color: rgba(255,255,255,.6); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* ── 列表 ─────────────────────────────── */
.list-section { margin: 20rpx 0 0; }
.section-head { display: flex; align-items: center; justify-content: space-between; padding: 0 24rpx 16rpx; }
.section-label-wrap { display: flex; align-items: center; gap: 12rpx; }
.label-bar { width: 6rpx; height: 30rpx; background: linear-gradient(180deg, #8B3FC0, #6B2FA0); border-radius: 3rpx; }
.section-label { font-size: 30rpx; font-weight: 600; color: #2C1810; }

.poem-item {
  display: flex; align-items: center;
  background: #FFFBF0;
  margin: 0 24rpx 14rpx;
  border-radius: 16rpx;
  padding: 18rpx 18rpx;
  border: 1rpx solid #EDD9A3;
  box-shadow: 0 2rpx 8rpx rgba(106,61,168,.05);
}
.poem-hover { background: #F5EDFF !important; }
.poem-left { flex-shrink: 0; margin-right: 16rpx; }
.poem-dynasty-tag {
  background: #6B2FA0; color: #FFF8E7;
  font-size: 20rpx; padding: 4rpx 12rpx;
  border-radius: 10rpx;
}
.song-tag { background: #2E8B6A !important; }
.yuan-tag { background: #E8A710 !important; }
.poem-info { flex: 1; }
.poem-title { display: block; font-size: 30rpx; color: #2C1810; font-weight: 600; margin-bottom: 4rpx; }
.poem-author { display: block; font-size: 22rpx; color: #8C7B61; margin-bottom: 6rpx; }
.poem-preview { display: block; font-size: 22rpx; color: #5A4030; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.poem-arr { font-size: 40rpx; color: #8B3FC0; font-weight: 300; flex-shrink: 0; }

/* ── 典籍网格 ─────────────────────────────── */
.books-section {}
.books-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; padding: 0 24rpx 24rpx; }
.book-card {
  background: #FFFBF0;
  border-radius: 20rpx;
  border: 1rpx solid #EDD9A3;
  padding: 20rpx;
  display: flex; flex-direction: column; align-items: center; text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(106,61,168,.06);
}
.book-hover { background: #F5EDFF !important; }
.book-icon-wrap {
  width: 80rpx; height: 80rpx;
  border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 12rpx;
}
.book-icon { font-size: 38rpx; }
.book-name { font-size: 32rpx; color: #2C1810; font-weight: 700; margin-bottom: 4rpx; }
.book-era { font-size: 19rpx; color: #8C7B61; margin-bottom: 8rpx; }
.book-desc { font-size: 20rpx; color: #5A4030; line-height: 1.5; margin-bottom: 12rpx; }
.book-highlights { display: flex; flex-direction: column; gap: 4rpx; width: 100%; }
.book-hl { font-size: 18rpx; color: #6B2FA0; background: #F0E0FF; padding: 3rpx 8rpx; border-radius: 8rpx; text-align: left; }

/* ── 朝代横幅 ─────────────────────────────── */
.dynasty-banner {
  margin: 0 24rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  display: flex; flex-direction: column; gap: 6rpx;
}
.tang-banner { background: linear-gradient(135deg, #FF9A5C, #E05820); }
.song-banner { background: linear-gradient(135deg, #43E97B, #2E8B6A); }
.yuan-banner { background: linear-gradient(135deg, #F7C948, #C48A10); }
.dynasty-banner-title { font-size: 32rpx; font-weight: 700; color: #FFF8E7; }
.dynasty-banner-sub { font-size: 22rpx; color: rgba(255,248,231,.75); }

/* ── 弹窗 ─────────────────────────────── */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,.5);
  display: flex; align-items: flex-end;
  z-index: 100;
}
.modal-box {
  background: #FFFBF0;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 80vh;
  display: flex; flex-direction: column;
  overflow: hidden;
}
.modal-header {
  display: flex; align-items: flex-start; justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #EDD9A3;
  background: linear-gradient(90deg, #6B2FA0, #8B3FC0);
  flex-shrink: 0;
}
.modal-title { display: block; font-size: 38rpx; font-weight: 700; color: #FFF8E7; }
.modal-author { display: block; font-size: 22rpx; color: rgba(255,248,231,.7); margin-top: 6rpx; }
.modal-close {
  width: 56rpx; height: 56rpx;
  background: rgba(255,255,255,.2);
  border-radius: 28rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #FFF8E7; flex-shrink: 0;
}
.close-hover { background: rgba(255,255,255,.35) !important; }
.modal-body {
  flex: 1; padding: 24rpx 32rpx; overflow: hidden;
  background: #FFFBF0;
}
.section-label-sm {
  display: block;
  font-size: 22rpx; color: #6B2FA0; font-weight: 600;
  background: #F0E0FF; border-left: 4rpx solid #6B2FA0;
  padding: 4rpx 12rpx; border-radius: 0 8rpx 8rpx 0;
  margin-bottom: 14rpx;
}
.poem-original {
  display: block; font-size: 28rpx; color: #2C1810;
  line-height: 2; white-space: pre-wrap;
  margin-bottom: 24rpx;
}
.poem-loading { display: flex; align-items: center; gap: 12rpx; padding: 20rpx 0; }
.ai-loading-icon-sm { font-size: 32rpx; }
.poem-analysis { margin-top: 8rpx; }
.analysis-text { display: block; font-size: 26rpx; color: #2C1810; line-height: 1.9; white-space: pre-wrap; }
.modal-actions {
  display: flex; gap: 16rpx;
  padding: 20rpx 32rpx;
  border-top: 1rpx solid #EDD9A3;
  flex-shrink: 0;
  background: #FFFBF0;
}
.modal-action-btn {
  flex: 1; height: 80rpx;
  border-radius: 40rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; font-weight: 500;
  border: 2rpx solid #6B2FA0;
  color: #6B2FA0;
}
.modal-btn-hover { opacity: 0.8 !important; }
.analyze-btn {
  background: linear-gradient(90deg, #6B2FA0, #8B3FC0);
  color: #FFF8E7;
  border-color: transparent;
}
.favorited { background: linear-gradient(90deg, #E05070, #C03060) !important; color: #FFF8E7 !important; border-color: transparent !important; }

.safe-bottom { height: env(safe-area-inset-bottom); background: #FDF6E3; }
