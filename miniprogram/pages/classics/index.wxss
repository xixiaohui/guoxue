/* pages/classics/index.wxss - 诗词典籍页样式 */

.classics-page {
  background: #FDF6E3;
}

/* 搜索栏 */
.search-header {
  background: #8B2500;
  padding: 16rpx 24rpx 24rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: rgba(255, 248, 231, 0.15);
  border: 1rpx solid rgba(255, 248, 231, 0.3);
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #FFF8E7;
  min-height: 48rpx;
}

.search-ph {
  color: rgba(255, 248, 231, 0.5);
}

.search-btn {
  font-size: 26rpx;
  color: #FFD97D;
  flex-shrink: 0;
}

/* 分类标签 */
.category-tabs {
  background: #FFFBF0;
  border-bottom: 1rpx solid #E8D5A3;
  white-space: nowrap;
}

.tab-list {
  display: flex;
  padding: 0 12rpx;
}

.tab-item {
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  color: #6B5B45;
  white-space: nowrap;
  position: relative;
}

.tab-item.active {
  color: #8B2500;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #8B2500;
  border-radius: 2rpx;
}

/* 搜索结果 */
.search-result-section {
  background: #FFFBF0;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #EDD9A3;
  overflow: hidden;
}

.result-header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(139, 37, 0, 0.06);
  border-bottom: 1rpx solid #EDD9A3;
}

.result-title {
  font-size: 28rpx;
  color: #8B2500;
  font-weight: 600;
}

.close-search {
  font-size: 32rpx;
  color: #8C7B61;
  padding: 4rpx 12rpx;
}

.ai-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  gap: 16rpx;
  font-size: 26rpx;
  color: #8C7B61;
}

.ai-result {
  padding: 24rpx;
}

.ai-result-text {
  font-size: 28rpx;
  color: #2C1810;
  line-height: 1.9;
  white-space: pre-wrap;
}

.result-actions-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-chip {
  background: #FFF3DC;
  border: 1rpx solid #E8C88A;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #6B3A10;
}

/* 内容滚动区 */
.content-scroll {
  flex: 1;
}

/* 精选推荐 */
.featured-section {
  padding: 20rpx 0;
}

.featured-list {
  display: flex;
  padding: 8rpx 24rpx 16rpx;
  gap: 20rpx;
}

.featured-card {
  width: 280rpx;
  height: 200rpx;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.12);
}

.card-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
}

.card-content {
  position: relative;
  z-index: 1;
  padding: 24rpx;
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.poem-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.poem-author {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.poem-preview {
  flex: 1;
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 16rpx;
  line-height: 1.6;
}

.poem-tag {
  display: inline-block;
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  align-self: flex-start;
}

/* 诗词列表 */
.poems-section {
  padding: 0 0 20rpx;
}

.poem-list {
  padding: 8rpx 24rpx;
}

.poem-item {
  display: flex;
  align-items: center;
  background: #FFFBF0;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #EDD9A3;
  box-shadow: 0 2rpx 8rpx rgba(139, 37, 0, 0.04);
}

.poem-item:active {
  background: #FFF5DC;
}

.poem-left {
  margin-right: 16rpx;
  flex-shrink: 0;
}

.poem-dynasty-badge {
  background: linear-gradient(135deg, #C4882E, #8B2500);
  color: #FFF8E7;
  font-size: 22rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
}

.poem-main {
  flex: 1;
}

.poem-name {
  display: block;
  font-size: 30rpx;
  color: #2C1810;
  font-weight: 600;
}

.poem-by {
  display: block;
  font-size: 22rpx;
  color: #C4882E;
  margin-top: 4rpx;
}

.poem-line {
  display: block;
  font-size: 24rpx;
  color: #8C7B61;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.poem-arrow {
  font-size: 40rpx;
  color: #C4882E;
  font-weight: 300;
}

/* 典籍网格 */
.classics-section {
  padding: 0 0 20rpx;
}

.classics-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 8rpx 24rpx;
}

.classic-card {
  background: #FFFBF0;
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  border: 1rpx solid #EDD9A3;
  box-shadow: 0 2rpx 10rpx rgba(139, 37, 0, 0.06);
}

.classic-card:active {
  background: #FFF5DC;
}

.classic-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 12rpx;
}

.classic-icon {
  font-size: 40rpx;
}

.classic-name {
  display: block;
  font-size: 28rpx;
  color: #2C1810;
  font-weight: 600;
}

.classic-desc {
  display: block;
  font-size: 20rpx;
  color: #8C7B61;
  margin-top: 6rpx;
  line-height: 1.4;
}

.classic-era {
  display: block;
  font-size: 20rpx;
  color: #C4882E;
  margin-top: 6rpx;
}

/* 诗词弹窗 */
.poem-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  background: #FFFBF0;
  border-radius: 30rpx 30rpx 0 0;
  width: 100%;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease-out;
}

.modal-header {
  padding: 30rpx 30rpx 20rpx;
  border-bottom: 1rpx solid #EDD9A3;
  position: relative;
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #2C1810;
}

.modal-subtitle {
  display: block;
  font-size: 24rpx;
  color: #C4882E;
  margin-top: 8rpx;
}

.modal-close {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  font-size: 32rpx;
  color: #8C7B61;
  padding: 8rpx;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx;
}

.section-label {
  display: block;
  font-size: 24rpx;
  color: #8B2500;
  font-weight: 600;
  margin-bottom: 16rpx;
  padding: 4rpx 16rpx;
  border-left: 4rpx solid #C4882E;
  background: rgba(196, 136, 46, 0.06);
}

.poem-original {
  margin-bottom: 24rpx;
}

.poem-full-text {
  font-size: 32rpx;
  color: #2C1810;
  line-height: 2;
  white-space: pre-wrap;
}

.poem-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  gap: 12rpx;
}

.loading-hint {
  font-size: 24rpx;
  color: #8C7B61;
}

.poem-analysis {
  margin-bottom: 24rpx;
}

.analysis-text {
  font-size: 26rpx;
  color: #4A3020;
  line-height: 1.9;
  white-space: pre-wrap;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-bottom: 20rpx;
}

.modal-action-btn {
  flex: 1;
  background: linear-gradient(135deg, rgba(196,136,46,0.1), rgba(139,37,0,0.08));
  border: 1rpx solid #C4882E;
  border-radius: 40rpx;
  padding: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8B2500;
}

.modal-action-btn:active {
  background: rgba(196, 136, 46, 0.2);
}
