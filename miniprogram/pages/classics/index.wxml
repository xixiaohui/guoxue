<!-- pages/classics/index.wxml - 诗词典籍页 -->
<view class="container classics-page">
  
  <!-- 顶部搜索栏 -->
  <view class="search-header">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input"
        placeholder="搜索诗词、典籍、作者..."
        placeholder-class="search-ph"
        value="{{searchText}}"
        bindinput="onSearchInput"
        bindconfirm="doSearch"
        confirm-type="search"
      />
      <text class="search-btn" bindtap="doSearch" wx:if="{{searchText}}">搜索</text>
    </view>
  </view>

  <!-- 分类标签 -->
  <scroll-view scroll-x class="category-tabs">
    <view class="tab-list">
      <view 
        class="tab-item {{activeTab === item.id ? 'active' : ''}}"
        wx:for="{{tabs}}"
        wx:key="id"
        bindtap="switchTab"
        data-id="{{item.id}}"
      >{{item.name}}</view>
    </view>
  </scroll-view>

  <!-- 搜索结果 -->
  <view class="search-result-section" wx:if="{{searchResult || isSearching}}">
    <view class="result-header-bar">
      <text class="result-title">AI解析结果</text>
      <text class="close-search" bindtap="closeSearch">✕</text>
    </view>
    
    <view class="ai-loading" wx:if="{{isSearching}}">
      <view class="loading-dots">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
      <text>正在检索分析中...</text>
    </view>
    
    <view class="ai-result" wx:elif="{{searchResult}}">
      <text class="ai-result-text" selectable>{{searchResult}}</text>
      <view class="result-actions-row">
        <view class="action-chip" bindtap="continueInChat">
          <text>💬 在问答中继续探讨</text>
        </view>
        <view class="action-chip" bindtap="copySearchResult">
          <text>📋 复制内容</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 内容区 -->
  <scroll-view scroll-y class="content-scroll" wx:if="{{!searchResult && !isSearching}}">
    
    <!-- 精选推荐 -->
    <view class="featured-section">
      <text class="section-title">精选推荐</text>
      <scroll-view scroll-x>
        <view class="featured-list">
          <view 
            class="featured-card"
            wx:for="{{featuredPoems}}"
            wx:key="id"
            bindtap="openPoem"
            data-poem="{{item}}"
          >
            <view class="card-bg" style="background: {{item.color}}"></view>
            <view class="card-content">
              <text class="poem-title">{{item.title}}</text>
              <text class="poem-author">{{item.author}}</text>
              <text class="poem-preview">{{item.preview}}</text>
              <view class="poem-tag">{{item.dynasty}}</view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 诗词列表 -->
    <view class="poems-section" wx:if="{{activeTab === 'poem'}}">
      <text class="section-title">经典诗词</text>
      <view class="poem-list">
        <view 
          class="poem-item"
          wx:for="{{poems}}"
          wx:key="id"
          bindtap="openPoem"
          data-poem="{{item}}"
        >
          <view class="poem-left">
            <view class="poem-dynasty-badge">{{item.dynasty}}</view>
          </view>
          <view class="poem-main">
            <text class="poem-name">{{item.title}}</text>
            <text class="poem-by">{{item.author}}</text>
            <text class="poem-line">{{item.preview}}</text>
          </view>
          <text class="poem-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 典籍列表 -->
    <view class="classics-section" wx:if="{{activeTab === 'classics'}}">
      <text class="section-title">经典典籍</text>
      <view class="classics-grid">
        <view 
          class="classic-card"
          wx:for="{{classicBooks}}"
          wx:key="id"
          bindtap="openClassic"
          data-book="{{item}}"
        >
          <view class="classic-icon-wrap" style="background: {{item.color}}">
            <text class="classic-icon">{{item.icon}}</text>
          </view>
          <text class="classic-name">{{item.name}}</text>
          <text class="classic-desc">{{item.desc}}</text>
          <text class="classic-era">{{item.era}}</text>
        </view>
      </view>
    </view>

  </scroll-view>

  <!-- 诗词详情弹窗 -->
  <view class="poem-modal" wx:if="{{showModal}}" bindtap="closeModal">
    <view class="modal-content" catchtap="stopProp">
      <view class="modal-header">
        <text class="modal-title">{{currentPoem.title}}</text>
        <text class="modal-subtitle">{{currentPoem.author}} · {{currentPoem.dynasty}}</text>
        <text class="modal-close" bindtap="closeModal">✕</text>
      </view>
      
      <scroll-view scroll-y class="modal-body">
        <!-- 原文 -->
        <view class="poem-original">
          <text class="section-label">原文</text>
          <text class="poem-full-text" selectable>{{currentPoem.content}}</text>
        </view>
        
        <!-- AI解析中 -->
        <view class="poem-loading" wx:if="{{poemLoading}}">
          <view class="loading-dots">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
          <text class="loading-hint">正在获取AI解析...</text>
        </view>
        
        <!-- AI解析 -->
        <view class="poem-analysis" wx:elif="{{currentPoem.analysis}}">
          <text class="section-label">AI赏析</text>
          <text class="analysis-text" selectable>{{currentPoem.analysis}}</text>
        </view>
        
        <view class="modal-actions">
          <view class="modal-action-btn" bindtap="analyzePoem">
            <text>🤖 深度解析</text>
          </view>
          <view class="modal-action-btn" bindtap="askAboutPoem">
            <text>💬 继续探讨</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
  
  <view class="safe-bottom"></view>
</view>
