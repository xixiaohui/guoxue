<!-- pages/classics/index.wxml - 诗词典籍页 v6.0 -->
<view class="classics-page">

  <!-- 页头 -->
  <view class="page-header">
    <view class="header-inner">
      <text class="header-title">诗词典籍</text>
      <text class="header-sub">经典传承 · 千年文脉</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-inner">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        value="{{searchText}}"
        bindinput="onSearchInput"
        placeholder="搜索诗词名句、作者、典籍…"
        placeholder-class="search-placeholder"
        confirm-type="search"
        bindconfirm="doSearch"
      />
      <view
        class="search-btn"
        bindtap="doSearch"
        hover-class="search-btn-hover"
        hover-stay-time="80"
        wx:if="{{!isSearching}}"
      >
        <text class="search-btn-text">搜索</text>
      </view>
      <view class="search-loading" wx:else>
        <text class="search-loading-text">…</text>
      </view>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="search-result-section" wx:if="{{searchResult || isSearching}}">
    <view class="result-header">
      <view class="result-title-row">
        <view class="result-dot"></view>
        <text class="result-title">AI解析结果</text>
      </view>
      <view class="result-actions">
        <view class="action-btn" wx:if="{{searchResult}}" bindtap="copySearchResult" hover-class="action-hover" hover-stay-time="80">
          <text>📋 复制</text>
        </view>
        <view class="action-btn close-btn" bindtap="closeSearch" hover-class="action-hover" hover-stay-time="80">
          <text>✕ 关闭</text>
        </view>
      </view>
    </view>
    <view class="result-loading" wx:if="{{isSearching}}">
      <view class="ai-loading-icon">📖</view>
      <text class="ai-loading-text">AI正在深度解析…</text>
    </view>
    <view class="result-body" wx:elif="{{searchSections.length > 0}}">
      <view class="seg-block" wx:for="{{searchSections}}" wx:key="index">
        <view class="seg-label-row">
          <view class="seg-dot"></view>
          <text class="seg-label">{{item.label}}</text>
        </view>
        <text class="seg-content">{{item.content}}</text>
      </view>
    </view>
  </view>

  <!-- 分类Tab -->
  <scroll-view scroll-x show-scrollbar="{{false}}" class="tabs-scroll" enhanced="{{true}}" bounces="{{false}}">
    <view class="tabs-row">
      <view
        class="tab-item {{activeTab === item.id ? 'tab-active' : ''}}"
        wx:for="{{tabs}}"
        wx:key="id"
        bindtap="switchTab"
        data-id="{{item.id}}"
        hover-class="tab-hover"
        hover-stay-time="80"
      >
        <text class="tab-icon">{{item.icon}}</text>
        <text class="tab-name">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 精选诗词 -->
  <view wx:if="{{activeTab === 'poem'}}">
    <!-- 精选推荐轮播区 -->
    <view class="featured-section">
      <scroll-view scroll-x show-scrollbar="{{false}}" class="featured-scroll" enhanced="{{true}}" bounces="{{false}}">
        <view class="featured-row">
          <view
            class="featured-card"
            wx:for="{{featuredPoems}}"
            wx:key="id"
            style="background:{{item.color}}"
            bindtap="openPoem"
            data-poem="{{item}}"
            hover-class="featured-hover"
            hover-stay-time="100"
          >
            <view class="featured-badge">精选</view>
            <text class="featured-desc">{{item.desc}}</text>
            <text class="featured-title">{{item.title}}</text>
            <text class="featured-author">{{item.dynasty}} · {{item.author}}</text>
            <text class="featured-preview">{{item.preview}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 更多诗词列表 -->
    <view class="list-section">
      <view class="section-head">
        <view class="section-label-wrap">
          <view class="label-bar"></view>
          <text class="section-label">更多诗词</text>
        </view>
      </view>
      <view
        class="poem-item"
        wx:for="{{poems}}"
        wx:key="id"
        bindtap="openPoem"
        data-poem="{{item}}"
        hover-class="poem-hover"
        hover-stay-time="80"
      >
        <view class="poem-left">
          <text class="poem-dynasty-tag">{{item.dynasty}}</text>
        </view>
        <view class="poem-info">
          <text class="poem-title">{{item.title}}</text>
          <text class="poem-author">{{item.author}}</text>
          <text class="poem-preview">{{item.preview}}</text>
        </view>
        <text class="poem-arr">›</text>
      </view>
    </view>
  </view>

  <!-- 经典典籍 -->
  <view wx:elif="{{activeTab === 'classics'}}">
    <view class="books-section">
      <view class="section-head" style="padding: 24rpx 24rpx 16rpx;">
        <view class="section-label-wrap">
          <view class="label-bar"></view>
          <text class="section-label">四部要典</text>
        </view>
      </view>
      <view class="books-grid">
        <view
          class="book-card"
          wx:for="{{classicBooks}}"
          wx:key="id"
          bindtap="openClassic"
          data-book="{{item}}"
          hover-class="book-hover"
          hover-stay-time="100"
        >
          <view class="book-icon-wrap" style="background:{{item.color}}">
            <text class="book-icon">{{item.icon}}</text>
          </view>
          <text class="book-name">{{item.name}}</text>
          <text class="book-era">{{item.era}}</text>
          <text class="book-desc">{{item.desc}}</text>
          <view class="book-highlights">
            <text
              class="book-hl"
              wx:for="{{item.highlights}}"
              wx:for-item="hl"
              wx:key="index"
            >「{{hl}}」</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 唐诗 -->
  <view wx:elif="{{activeTab === 'tang'}}">
    <view class="list-section" style="margin-top:24rpx;">
      <view class="dynasty-banner tang-banner">
        <text class="dynasty-banner-title">盛唐气象</text>
        <text class="dynasty-banner-sub">李白·杜甫·王维·白居易 群星璀璨</text>
      </view>
      <view
        class="poem-item"
        wx:for="{{tangPoems}}"
        wx:key="id"
        bindtap="openPoem"
        data-poem="{{item}}"
        hover-class="poem-hover"
        hover-stay-time="80"
      >
        <view class="poem-left">
          <text class="poem-dynasty-tag">唐</text>
        </view>
        <view class="poem-info">
          <text class="poem-title">{{item.title}}</text>
          <text class="poem-author">{{item.author}}</text>
          <text class="poem-preview">{{item.preview}}</text>
        </view>
        <text class="poem-arr">›</text>
      </view>
    </view>
  </view>

  <!-- 宋词 -->
  <view wx:elif="{{activeTab === 'song'}}">
    <view class="list-section" style="margin-top:24rpx;">
      <view class="dynasty-banner song-banner">
        <text class="dynasty-banner-title">词章风骨</text>
        <text class="dynasty-banner-sub">苏轼·辛弃疾·李清照 情词雅韵</text>
      </view>
      <view
        class="poem-item"
        wx:for="{{songCi}}"
        wx:key="id"
        bindtap="openPoem"
        data-poem="{{item}}"
        hover-class="poem-hover"
        hover-stay-time="80"
      >
        <view class="poem-left">
          <text class="poem-dynasty-tag song-tag">宋</text>
        </view>
        <view class="poem-info">
          <text class="poem-title">{{item.title}}</text>
          <text class="poem-author">{{item.author}}</text>
          <text class="poem-preview">{{item.preview}}</text>
        </view>
        <text class="poem-arr">›</text>
      </view>
    </view>
  </view>

  <!-- 元曲 -->
  <view wx:elif="{{activeTab === 'yuan'}}">
    <view class="list-section" style="margin-top:24rpx;">
      <view class="dynasty-banner yuan-banner">
        <text class="dynasty-banner-title">曲韵悠扬</text>
        <text class="dynasty-banner-sub">马致远·张养浩·白朴 散曲精华</text>
      </view>
      <view
        class="poem-item"
        wx:for="{{yuanQu}}"
        wx:key="id"
        bindtap="openPoem"
        data-poem="{{item}}"
        hover-class="poem-hover"
        hover-stay-time="80"
      >
        <view class="poem-left">
          <text class="poem-dynasty-tag yuan-tag">元</text>
        </view>
        <view class="poem-info">
          <text class="poem-title">{{item.title}}</text>
          <text class="poem-author">{{item.author}}</text>
          <text class="poem-preview">{{item.preview}}</text>
        </view>
        <text class="poem-arr">›</text>
      </view>
    </view>
  </view>

  <!-- 诗词详情弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal">
    <view class="modal-box" catchtap="stopProp">
      <view class="modal-header">
        <view>
          <text class="modal-title">{{currentPoem.title}}</text>
          <text class="modal-author">{{currentPoem.dynasty}} · {{currentPoem.author}}</text>
        </view>
        <view class="modal-close" bindtap="closeModal" hover-class="close-hover" hover-stay-time="80">✕</view>
      </view>

      <scroll-view scroll-y class="modal-body" enhanced="{{true}}">
        <!-- 原文 -->
        <view class="section-label-sm">原文</view>
        <text class="poem-original">{{currentPoem.content}}</text>

        <!-- AI赏析 -->
        <view wx:if="{{poemLoading}}" class="poem-loading">
          <text class="ai-loading-icon-sm">🤔</text>
          <text class="ai-loading-text">AI正在赏析中…</text>
        </view>
        <view wx:elif="{{currentPoem.analysis}}" class="poem-analysis">
          <view class="section-label-sm">AI赏析</view>
          <text class="analysis-text">{{currentPoem.analysis}}</text>
        </view>
      </scroll-view>

      <view class="modal-actions">
        <view
          class="modal-action-btn favor-btn {{isFavorited ? 'favorited' : ''}}"
          bindtap="toggleFavoritePoem"
          hover-class="modal-btn-hover"
          hover-stay-time="80"
        >
          <text>{{isFavorited ? '❤️ 已收藏' : '🤍 收藏'}}</text>
        </view>
        <view
          class="modal-action-btn analyze-btn"
          bindtap="analyzePoem"
          hover-class="modal-btn-hover"
          hover-stay-time="80"
        >
          <text>{{poemLoading ? '分析中…' : (currentPoem.analysis ? '✓ 已解析' : '✨ AI赏析')}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
