<!-- pages/chat/index.wxml - 生产级AI问答 v5.0（双模型切换） -->
<view class="chat-page">

  <!-- 顶部栏 -->
  <view class="chat-nav">
    <view class="nav-ai-info">
      <view class="ai-badge">文</view>
      <view class="ai-meta">
        <text class="ai-name">文渊先生</text>
        <text class="ai-state {{isTyping ? 'state-thinking' : 'state-online'}}">
          {{isTyping ? '正在思考...' : '国学AI · 在线'}}
        </text>
      </view>
    </view>
    <view class="nav-actions">
      <!-- 模型切换按钮 -->
      <view class="model-btn" bindtap="openModelPicker">
        <text class="model-btn-icon">{{currentModel === 'deepseek' ? '🧠' : '🔥'}}</text>
        <text class="model-btn-label">{{currentModel === 'deepseek' ? 'DeepSeek' : '混元'}}</text>
      </view>
      <!-- 配额/会员徽章 -->
      <view
        class="quota-badge {{quotaStatus && quotaStatus.isVip ? 'badge-vip' : (quotaStatus && quotaStatus.hasAdBonus ? 'badge-bonus' : 'badge-free')}}"
        bindtap="goVip"
        wx:if="{{quotaBadge}}"
      >{{quotaBadge}}</view>
      <view class="nav-btn" bindtap="showHistoryPanel">
        <text class="nav-btn-icon">📋</text>
      </view>
      <view class="nav-btn" bindtap="clearChat">
        <text class="nav-btn-icon">🗑</text>
      </view>
    </view>
  </view>

  <!-- 配额提示条（非VIP显示） -->
  <view
    class="quota-bar {{quotaStatus && quotaStatus.remaining <= 1 ? 'quota-bar-warn' : ''}}"
    wx:if="{{showQuotaBar && quotaStatus && !quotaStatus.isVip}}"
    bindtap="goVip"
  >
    <text class="quota-bar-text">
      <text wx:if="{{quotaStatus.remaining <= 0}}">❗ 今日免费次数已用完 · 点击解锁</text>
      <text wx:elif="{{quotaStatus.remaining === 1}}">⚡ 最后1次免费机会 · 点击升级会员</text>
      <text wx:else>💬 今日剩余 {{quotaStatus.remaining}} 次免费 · 升级会员无限使用</text>
    </text>
    <text class="quota-bar-arrow">›</text>
  </view>

  <!-- 消息区（使用 scroll-view 实现平滑滚动） -->
  <scroll-view
    class="msg-scroll"
    scroll-y="{{true}}"
    scroll-into-view="{{scrollToId}}"
    scroll-with-animation="{{true}}"
    enable-passive="{{true}}"
    show-scrollbar="{{false}}"
    enhanced="{{true}}"
  >
    <!-- 空状态：欢迎屏 -->
    <view class="welcome-screen" wx:if="{{messages.length === 0}}">
      <view class="welcome-avatar-wrap">
        <view class="welcome-avatar">文</view>
        <view class="avatar-ring"></view>
      </view>
      <text class="welcome-name">文渊先生</text>
      <text class="welcome-desc">融贯经史，博古通今。无论诗词赏析、古文翻译，还是历史人文，皆可一问。</text>

      <!-- 会员提示卡 -->
      <view class="vip-promo-card" bindtap="goVip" wx:if="{{quotaStatus && !quotaStatus.isVip && !quotaStatus.hasAdBonus}}">
        <view class="promo-left">
          <view class="promo-crown">👑</view>
          <view>
            <view class="promo-title">升级会员</view>
            <view class="promo-sub">无限对话 · 去广告 · 语音朗读</view>
          </view>
        </view>
        <view class="promo-price">9.9元/月 ›</view>
      </view>

      <!-- 快捷话题 -->
      <view class="quick-grid">
        <view
          class="quick-item"
          wx:for="{{quickTopics}}"
          wx:key="index"
          bindtap="onQuickTopic"
          data-topic="{{item}}"
          hover-class="quick-item-hover"
          hover-stay-time="100"
        >
          <text class="quick-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 消息列表 -->
    <view class="msg-list" wx:else>
      <view
        class="msg-row {{item.role === 'user' ? 'row-user' : 'row-ai'}}"
        wx:for="{{messages}}"
        wx:key="id"
        id="msg-{{item.id}}"
      >
        <!-- AI 头像 -->
        <view class="msg-avatar ai-avatar-sm" wx:if="{{item.role === 'assistant'}}">文</view>

        <view class="msg-body">
          <!-- 气泡 -->
          <view class="bubble {{item.role === 'user' ? 'bubble-user' : 'bubble-ai'}} {{item.error ? 'bubble-error' : ''}}">
            <!-- 打字动画 -->
            <view class="typing-dots" wx:if="{{item.isTyping && !item.content}}">
              <view class="typing-dot"></view>
              <view class="typing-dot"></view>
              <view class="typing-dot"></view>
            </view>
            <!-- 流式内容（边生成边显示）-->
            <text
              class="bubble-text"
              wx:elif="{{!item.error}}"
              selectable="{{!item.isTyping}}"
              space="nbsp"
              user-select="{{!item.isTyping}}"
            >{{item.content}}</text>
            <!-- 错误状态 -->
            <view wx:else class="error-body">
              <text class="error-icon">⚠️</text>
              <text class="error-text">{{item.content}}</text>
              <view class="retry-btn" bindtap="retryMsg" data-id="{{item.id}}" hover-class="btn-hover" hover-stay-time="100">重试</view>
            </view>
          </view>

          <!-- 时间 + 操作 -->
          <view class="msg-footer {{item.role === 'user' ? 'footer-user' : 'footer-ai'}}" wx:if="{{!item.isTyping && item.content}}">
            <text class="msg-time">{{item.time}}</text>
            <view class="msg-actions" wx:if="{{!item.error}}">
              <view class="copy-btn" bindtap="copyMsg" data-content="{{item.content}}" hover-class="action-hover" hover-stay-time="100">复制</view>
              <view
                class="speak-btn {{speakMsgId === item.id ? 'speaking' : ''}}"
                bindtap="speakMsg"
                data-content="{{item.content}}"
                data-id="{{item.id}}"
                wx:if="{{item.role === 'assistant'}}"
                hover-class="action-hover"
                hover-stay-time="100"
              >{{speakMsgId === item.id ? '🔊' : '🔈'}}</view>
            </view>
          </view>
        </view>

        <!-- 用户头像 -->
        <view class="msg-avatar user-avatar-sm" wx:if="{{item.role === 'user'}}">我</view>
      </view>

      <!-- 流式光标（AI 正在输出时显示） -->
      <view class="stream-cursor" wx:if="{{isTyping}}"></view>
    </view>

    <view id="chat-bottom" style="height:20rpx"></view>
  </scroll-view>

  <!-- 推荐追问 -->
  <scroll-view
    class="suggestions-bar"
    scroll-x="{{true}}"
    show-scrollbar="{{false}}"
    wx:if="{{suggestions.length > 0 && !isTyping}}"
    enable-passive="{{true}}"
  >
    <view class="sug-row">
      <view
        class="sug-chip"
        wx:for="{{suggestions}}"
        wx:key="index"
        bindtap="onSuggestion"
        data-text="{{item}}"
        hover-class="sug-hover"
        hover-stay-time="100"
      >{{item}}</view>
    </view>
  </scroll-view>

  <!-- 输入栏 -->
  <view class="input-bar">
    <view class="input-box">
      <textarea
        class="input-textarea"
        placeholder="问文渊先生..."
        placeholder-class="input-ph"
        value="{{inputText}}"
        bindinput="onInput"
        bindconfirm="sendMessage"
        auto-height="{{true}}"
        maxlength="600"
        cursor-spacing="20"
        confirm-type="send"
        show-confirm-bar="{{false}}"
      />
    </view>
    <view
      class="send-btn {{inputText.trim() && !isTyping ? 'send-active' : 'send-off'}}"
      bindtap="sendMessage"
      hover-class="send-hover"
      hover-stay-time="80"
    >
      <text class="send-icon">{{isTyping ? '⏳' : '➤'}}</text>
    </view>
  </view>

  <!-- 模型选择器弹窗 -->
  <view class="modal-mask" wx:if="{{showModelPicker}}" bindtap="closeModelPicker">
    <view class="model-picker-panel" catchtap="noop">
      <view class="picker-header">
        <text class="picker-title">选择AI模型</text>
        <text class="picker-close" bindtap="closeModelPicker">✕</text>
      </view>
      <view class="model-option-list">
        <view
          class="model-option {{currentModel === item.id ? 'model-option-active' : ''}}"
          wx:for="{{modelOptions}}"
          wx:key="id"
          bindtap="selectModel"
          data-id="{{item.id}}"
          hover-class="option-hover"
          hover-stay-time="100"
        >
          <text class="option-icon">{{item.icon}}</text>
          <view class="option-info">
            <text class="option-name">{{item.name}}</text>
            <text class="option-desc">{{item.desc}}</text>
          </view>
          <view class="option-check" wx:if="{{currentModel === item.id}}">✓</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 历史会话弹窗 -->
  <view class="history-mask" wx:if="{{showHistory}}" bindtap="closeHistory">
    <view class="history-panel" catchtap="noop">
      <view class="panel-header">
        <text class="panel-title">历史会话</text>
        <text class="panel-close" bindtap="closeHistory">✕</text>
      </view>
      <scroll-view scroll-y="{{true}}" class="panel-body" enable-passive="{{true}}">
        <view wx:if="{{historyList.length === 0}}" class="panel-empty">
          <text>暂无历史会话</text>
        </view>
        <view
          class="history-item"
          wx:for="{{historyList}}"
          wx:key="id"
          bindtap="loadHistorySession"
          data-session="{{item}}"
          hover-class="history-item-hover"
          hover-stay-time="100"
        >
          <view class="hi-meta">
            <text class="hi-time">{{item.time}}</text>
            <text class="hi-count">{{item.count}}条消息</text>
          </view>
          <text class="hi-preview">{{item.preview}}...</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="safe-area-bottom"></view>
</view>
