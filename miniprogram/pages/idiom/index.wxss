/* pages/idiom/index.wxss - 成语故事样式 v6.0 */

.idiom-page { background: #FDF6E3; min-height: 100vh; }

/* ── 页头 ─────────────────────────────── */
.page-header {
  background: linear-gradient(160deg, #7A3A00 0%, #C48A10 55%, #E0A820 100%);
  padding: 32rpx 30rpx 44rpx;
}
.header-title { display: block; font-size: 42rpx; font-weight: 700; color: #FFF8E7; letter-spacing: 4rpx; }
.header-sub { display: block; font-size: 24rpx; color: rgba(255,248,231,.6); margin-top: 8rpx; letter-spacing: 3rpx; }

/* ── 搜索栏 ─────────────────────────────── */
.search-bar {
  margin: -20rpx 24rpx 0;
  background: #FFFBF0;
  border-radius: 20rpx;
  padding: 12rpx 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(196,136,46,.2);
  border: 1rpx solid #E8C88A;
}
.search-inner { display: flex; align-items: center; gap: 10rpx; }
.search-icon { font-size: 28rpx; flex-shrink: 0; }
.search-input { flex: 1; font-size: 26rpx; color: #2C1810; height: 56rpx; }
.search-placeholder { color: #B09070; font-size: 24rpx; }
.search-btn {
  background: linear-gradient(90deg, #C48A10, #E0A820);
  border-radius: 20rpx; padding: 8rpx 24rpx;
}
.search-btn-hover { opacity: 0.8 !important; }
.search-btn-text { font-size: 24rpx; color: #FFF8E7; font-weight: 500; }

/* ── AI解析结果 ─────────────────────────────── */
.result-section {
  background: #FFFBF0;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  border: 1rpx solid #C48A10;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(196,136,46,.15);
}
.result-header {
  background: linear-gradient(90deg, #7A3A00, #C48A10);
  padding: 16rpx 20rpx;
  display: flex; align-items: center; justify-content: space-between;
}
.result-title-row { display: flex; align-items: center; gap: 10rpx; }
.result-dot { width: 10rpx; height: 10rpx; background: #FFD97D; border-radius: 50%; }
.result-title { font-size: 26rpx; color: #FFF8E7; font-weight: 600; }
.result-header-actions { display: flex; gap: 12rpx; }
.action-btn {
  background: rgba(255,255,255,.2); border-radius: 20rpx;
  padding: 6rpx 16rpx; font-size: 24rpx; color: #FFF8E7;
}
.action-hover { background: rgba(255,255,255,.35) !important; }
.result-loading { display: flex; flex-direction: column; align-items: center; padding: 40rpx; gap: 16rpx; }
.ai-loading-icon { font-size: 56rpx; animation: swing 1.5s infinite; }
@keyframes swing { 0%,100% { transform: rotate(-8deg); } 50% { transform: rotate(8deg); } }
.ai-loading-text { font-size: 24rpx; color: #8C7B61; }
.result-body { padding: 24rpx; }
.seg-block { margin-bottom: 20rpx; }
.seg-label-row { display: flex; align-items: center; gap: 10rpx; margin-bottom: 8rpx; }
.seg-dot { width: 8rpx; height: 28rpx; background: linear-gradient(180deg, #C48A10, #7A3A00); border-radius: 4rpx; }
.seg-label { font-size: 26rpx; font-weight: 600; color: #7A3A00; }
.seg-content { font-size: 28rpx; color: #2C1810; line-height: 1.9; padding-left: 18rpx; white-space: pre-wrap; }
.result-foot-actions { display: flex; gap: 16rpx; margin-top: 20rpx; padding-top: 16rpx; border-top: 1rpx solid #EDD9A3; }
.foot-btn {
  flex: 1; height: 72rpx; border: 2rpx solid #C48A10;
  border-radius: 36rpx; display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; color: #7A3A00;
}
.btn-hover { opacity: 0.8 !important; }

/* ── 每日成语 ─────────────────────────────── */
.daily-section { margin-top: 28rpx; }
.section-head { display: flex; align-items: center; justify-content: space-between; padding: 0 24rpx 16rpx; }
.section-label-wrap { display: flex; align-items: center; gap: 12rpx; }
.label-bar { width: 6rpx; height: 30rpx; background: linear-gradient(180deg, #C48A10, #7A3A00); border-radius: 3rpx; }
.section-label { font-size: 30rpx; font-weight: 600; color: #2C1810; }
.change-btn { border: 1rpx solid #C48A10; border-radius: 24rpx; padding: 6rpx 18rpx; background: #FFFBF0; }
.change-text { font-size: 24rpx; color: #C48A10; }

.daily-card {
  background: linear-gradient(135deg, #FFFBF0, #FFF5DC);
  border-radius: 20rpx;
  margin: 0 24rpx;
  padding: 28rpx;
  border: 1rpx solid #E8C88A;
  box-shadow: 0 6rpx 24rpx rgba(196,136,46,.15);
  position: relative; overflow: hidden;
}
.daily-card-bg-char {
  position: absolute; right: -24rpx; bottom: -30rpx;
  font-size: 160rpx; color: rgba(196,136,46,.06);
  font-weight: 900; line-height: 1; pointer-events: none;
  letter-spacing: -10rpx;
}
.skeleton-card { animation: shimmer 1.5s infinite; }
@keyframes shimmer { 0%,100% { opacity: 1; } 50% { opacity: .55; } }
.sk-line { background: #E8C88A; border-radius: 6rpx; }
.sk-w100 { width: 100%; } .sk-w80 { width: 80%; } .sk-w60 { width: 60%; } .sk-w40 { width: 40%; }
.sk-h40 { height: 40rpx; } .sk-h24 { height: 24rpx; } .sk-h22 { height: 22rpx; }
.sk-mb10 { margin-bottom: 10rpx; } .sk-mb16 { margin-bottom: 16rpx; } .sk-mb8 { margin-bottom: 8rpx; }

.daily-top {}
.daily-word { display: block; font-size: 52rpx; font-weight: 700; color: #8B2500; letter-spacing: 8rpx; margin-bottom: 8rpx; }
.daily-pinyin { display: block; font-size: 22rpx; color: #C48A10; margin-bottom: 12rpx; letter-spacing: 4rpx; }
.daily-brief { display: block; font-size: 26rpx; color: #4A3020; line-height: 1.7; }
.daily-sep { height: 1rpx; background: linear-gradient(90deg,transparent,#C48A10,transparent); margin: 18rpx 0; }
.daily-story-section { margin-bottom: 16rpx; }
.story-label { display: block; font-size: 22rpx; color: #C48A10; font-weight: 600; margin-bottom: 8rpx; }
.daily-story { display: block; font-size: 26rpx; color: #2C1810; line-height: 1.85; }
.daily-extra { display: flex; align-items: center; gap: 10rpx; margin-bottom: 12rpx; }
.extra-label { font-size: 22rpx; color: #8C7B61; background: #FFF0DC; padding: 3rpx 12rpx; border-radius: 10rpx; flex-shrink: 0; }
.extra-text { font-size: 22rpx; color: #5A4030; font-style: italic; }
.daily-tags { display: flex; flex-direction: column; gap: 8rpx; margin-bottom: 16rpx; }
.tag-item { display: flex; align-items: center; gap: 8rpx; }
.tag-label { font-size: 22rpx; color: #C48A10; font-weight: 500; flex-shrink: 0; }
.tag-val { font-size: 22rpx; color: #5A4030; }
.daily-actions { display: flex; gap: 16rpx; }
.daily-action-btn {
  flex: 1; height: 76rpx;
  border-radius: 38rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; font-weight: 500;
}
.primary-btn { background: linear-gradient(90deg, #C48A10, #E0A820); color: #FFF8E7; }
.outline-btn { border: 2rpx solid #C48A10; color: #7A3A00; }

/* ── 分类Tab ─────────────────────────────── */
.category-section { margin-top: 28rpx; }
.cat-scroll { padding: 0 24rpx; white-space: nowrap; }
.cat-row { display: inline-flex; gap: 14rpx; padding-bottom: 8rpx; }
.cat-chip {
  display: inline-flex; align-items: center; gap: 8rpx;
  background: #FFFBF0; border: 1rpx solid #E8C88A;
  border-radius: 32rpx; padding: 12rpx 20rpx;
  white-space: nowrap;
}
.chip-hover { background: #FFF0CC !important; }
.cat-active {
  background: linear-gradient(135deg, #C48A10, #E0A820);
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(196,136,46,.3);
}
.cat-chip-icon { font-size: 24rpx; }
.cat-chip-name { font-size: 24rpx; color: #4A3020; }
.cat-active .cat-chip-name { color: #FFF8E7; }
.cat-chip-count { font-size: 19rpx; color: #8C7B61; }
.cat-active .cat-chip-count { color: rgba(255,248,231,.75); }

/* ── 精选成语故事 ─────────────────────────────── */
.featured-section { margin-top: 28rpx; }
.featured-item {
  background: #FFFBF0;
  border-radius: 20rpx;
  margin: 0 24rpx 16rpx;
  padding: 24rpx;
  border: 1rpx solid #E8C88A;
  box-shadow: 0 2rpx 10rpx rgba(196,136,46,.08);
}
.item-hover { background: #FFF5DC !important; }
.feat-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 12rpx; }
.feat-word-wrap { flex: 1; }
.feat-word { display: block; font-size: 36rpx; font-weight: 700; color: #8B2500; margin-bottom: 4rpx; }
.feat-pinyin { display: block; font-size: 20rpx; color: #C48A10; }
.feat-cat-tag {
  background: #8B2500; color: #FFF8E7;
  font-size: 19rpx; padding: 4rpx 14rpx;
  border-radius: 12rpx; flex-shrink: 0;
  margin-top: 6rpx;
}
.feat-brief { display: block; font-size: 26rpx; color: #5A4030; font-weight: 500; margin-bottom: 12rpx; }
.feat-story {
  display: block; font-size: 24rpx; color: #4A3020; line-height: 1.8;
  background: rgba(196,136,46,.06);
  border-left: 4rpx solid #C48A10;
  padding: 12rpx 16rpx;
  border-radius: 0 10rpx 10rpx 0;
  margin-bottom: 14rpx;
}
.feat-footer { text-align: right; }
.feat-cta { font-size: 22rpx; color: #C48A10; }

/* ── 快速查询 ─────────────────────────────── */
.quick-section { margin-top: 28rpx; }
.quick-grid {
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 14rpx; padding: 0 24rpx 40rpx;
}
.quick-item {
  background: #FFFBF0;
  border-radius: 16rpx;
  padding: 18rpx 16rpx;
  border: 1rpx solid #E8C88A;
  box-shadow: 0 2rpx 8rpx rgba(196,136,46,.06);
}
.quick-hover { background: #FFF5DC !important; }
.quick-word { display: block; font-size: 30rpx; font-weight: 700; color: #8B2500; margin-bottom: 6rpx; }
.quick-brief { display: block; font-size: 20rpx; color: #6B5B45; line-height: 1.5; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }

.safe-bottom { height: env(safe-area-inset-bottom); background: #FDF6E3; }
