<!-- pages/idiom/index.wxml - 成语故事页 v5.0 -->
<view class="container idiom-page">

  <!-- 顶部搜索 -->
  <view class="idiom-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <text class="header-title">成语故事</text>
      <text class="header-subtitle">字里乾坤，典故传承</text>
    </view>
    <view class="search-wrap">
      <input
        class="idiom-search"
        placeholder="输入成语进行查询..."
        placeholder-class="search-ph"
        value="{{searchText}}"
        bindinput="onSearchInput"
        bindconfirm="searchIdiom"
        confirm-type="search"
      />
      <view class="search-action" bindtap="searchIdiom" hover-class="search-hover" hover-stay-time="80">查</view>
    </view>
  </view>

  <!-- 每日成语 -->
  <view class="daily-idiom">
    <view class="daily-idiom-header">
      <text class="daily-label">📖 每日一成语</text>
      <view class="change-idiom-btn" bindtap="changeDailyIdiom" hover-class="change-hover" hover-stay-time="80">
        <text>{{dailyIdiomLoading ? '加载中...' : '换一个'}}</text>
      </view>
    </view>

    <!-- 骨架屏 -->
    <view class="daily-idiom-skeleton" wx:if="{{dailyIdiomLoading}}">
      <view class="sk-word"></view>
      <view class="sk-pinyin"></view>
      <view class="sk-brief"></view>
    </view>

    <!-- AI生成的每日成语 -->
    <view
      class="daily-idiom-card"
      wx:else
      bindtap="lookupDailyIdiom"
      hover-class="card-hover"
      hover-stay-time="100"
    >
      <view class="idiom-card-top">
        <view class="idiom-word-block">
          <text class="idiom-word">{{dailyIdiom.word}}</text>
          <text class="idiom-pinyin">{{dailyIdiom.pinyin}}</text>
        </view>
        <view class="idiom-origin-tag" wx:if="{{dailyIdiom.origin}}">
          <text class="origin-text">{{dailyIdiom.origin}}</text>
        </view>
      </view>
      <text class="idiom-brief">{{dailyIdiom.brief}}</text>
      <view class="idiom-story-box" wx:if="{{dailyIdiom.story}}">
        <text class="story-label">典故</text>
        <text class="story-text">{{dailyIdiom.story}}</text>
      </view>
      <view class="idiom-extra-row" wx:if="{{dailyIdiom.synonym || dailyIdiom.antonym}}">
        <text class="extra-item" wx:if="{{dailyIdiom.synonym}}">近义：{{dailyIdiom.synonym}}</text>
        <text class="extra-item" wx:if="{{dailyIdiom.antonym}}">反义：{{dailyIdiom.antonym}}</text>
      </view>
      <view class="tap-hint">点击查看详解 →</view>
    </view>
  </view>

  <!-- 查询结果 -->
  <view class="result-section" wx:if="{{result || isLoading}}">
    <view class="result-card">
      <view class="result-word-header">
        <text class="result-word">{{currentIdiom}}</text>
        <view class="action-row">
          <view
            class="icon-btn {{isFavorited ? 'icon-btn-active' : ''}}"
            bindtap="toggleFavorite"
            hover-class="btn-hover"
            hover-stay-time="80"
          >
            {{isFavorited ? '❤️' : '🤍'}}
          </view>
          <view class="icon-btn" bindtap="copyResult" hover-class="btn-hover" hover-stay-time="80">📋</view>
          <view class="icon-btn" bindtap="chatAboutIdiom" hover-class="btn-hover" hover-stay-time="80">💬</view>
        </view>
      </view>

      <!-- 加载中 -->
      <view class="ai-loading" wx:if="{{isLoading}}">
        <view class="loading-dots">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
        </view>
        <text class="loading-text">正在查询成语...</text>
      </view>

      <!-- 分段展示 -->
      <view class="result-sections" wx:elif="{{resultSections.length > 0}}">
        <view class="result-seg" wx:for="{{resultSections}}" wx:key="label">
          <view class="seg-label-row">
            <view class="seg-dot"></view>
            <text class="seg-label">{{item.label}}</text>
          </view>
          <text class="seg-content" selectable="{{true}}">{{item.content}}</text>
        </view>
      </view>

      <!-- 纯文本降级 -->
      <text class="result-content-text fade-in" selectable="{{true}}" wx:elif="{{result}}">{{result}}</text>
    </view>
  </view>

  <!-- 成语分类 -->
  <view class="categories-section">
    <text class="section-title">成语分类</text>
    <view class="cat-grid">
      <view
        class="cat-item"
        wx:for="{{idiomCategories}}"
        wx:key="id"
        bindtap="exploreCat"
        data-cat="{{item}}"
        style="background: {{item.bg}}"
        hover-class="cat-hover"
        hover-stay-time="100"
      >
        <text class="cat-emoji">{{item.icon}}</text>
        <text class="cat-name">{{item.name}}</text>
        <text class="cat-count">{{item.count}}个</text>
      </view>
    </view>
  </view>

  <!-- 精选成语 -->
  <view class="featured-idioms">
    <text class="section-title">精选成语</text>
    <view class="idioms-list">
      <view
        class="idiom-item"
        wx:for="{{featuredIdioms}}"
        wx:key="id"
        bindtap="lookupIdiom"
        data-idiom="{{item.word}}"
        hover-class="idiom-hover"
        hover-stay-time="100"
      >
        <view class="idiom-word-wrap">
          <text class="featured-word">{{item.word}}</text>
          <text class="featured-pinyin">{{item.pinyin}}</text>
        </view>
        <text class="featured-brief">{{item.brief}}</text>
        <view class="idiom-tags">
          <text class="idiom-cat-tag">{{item.category}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 已知成语列表（新增） -->
  <view class="known-idioms-section" wx:if="{{knownIdioms.length > 0}}">
    <text class="section-title">常见成语</text>
    <scroll-view scroll-x="{{true}}" show-scrollbar="{{false}}" enable-passive="{{true}}">
      <view class="known-list">
        <view
          class="known-item"
          wx:for="{{knownIdioms}}"
          wx:key="word"
          bindtap="lookupIdiom"
          data-idiom="{{item.word}}"
          hover-class="known-hover"
          hover-stay-time="80"
        >
          <text class="known-word">{{item.word}}</text>
          <text class="known-cat">{{item.category}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="safe-bottom"></view>
</view>
