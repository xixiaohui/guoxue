<!-- pages/idiom/index.wxml - 成语故事页 v6.0 -->
<view class="idiom-page">

  <!-- 页头 -->
  <view class="page-header">
    <view class="header-inner">
      <text class="header-title">成语故事</text>
      <text class="header-sub">字里乾坤 · 典故传承</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-inner">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        value="{{searchText}}"
        bindinput="onSearchInput"
        placeholder="输入成语查询详解，如：一鸣惊人…"
        placeholder-class="search-placeholder"
        confirm-type="search"
        bindconfirm="searchIdiom"
      />
      <view class="search-btn" bindtap="searchIdiom" hover-class="search-btn-hover" hover-stay-time="80">
        <text class="search-btn-text">查询</text>
      </view>
    </view>
  </view>

  <!-- AI解析结果 -->
  <view class="result-section" wx:if="{{result || isLoading}}">
    <view class="result-header">
      <view class="result-title-row">
        <view class="result-dot"></view>
        <text class="result-title">「{{currentIdiom}}」解析</text>
      </view>
      <view class="result-header-actions">
        <view class="action-btn" wx:if="{{result}}" bindtap="copyResult" hover-class="action-hover" hover-stay-time="80">
          <text>📋</text>
        </view>
        <view class="action-btn close-btn" bindtap="closeResult" hover-class="action-hover" hover-stay-time="80">
          <text>✕</text>
        </view>
      </view>
    </view>

    <!-- 加载中 -->
    <view class="result-loading" wx:if="{{isLoading}}">
      <view class="ai-loading-icon">🤔</view>
      <text class="ai-loading-text">AI正在溯源成语故事…</text>
    </view>

    <!-- 分段结果 -->
    <view class="result-body" wx:elif="{{resultSections.length > 0}}">
      <view class="seg-block" wx:for="{{resultSections}}" wx:key="index">
        <view class="seg-label-row">
          <view class="seg-dot"></view>
          <text class="seg-label">{{item.label}}</text>
        </view>
        <text class="seg-content">{{item.content}}</text>
      </view>
      <view class="result-foot-actions">
        <view class="foot-btn" bindtap="toggleFavorite" hover-class="btn-hover" hover-stay-time="80">
          <text>{{isFavorited ? '❤️ 已收藏' : '🤍 收藏'}}</text>
        </view>
        <view class="foot-btn" bindtap="copyResult" hover-class="btn-hover" hover-stay-time="80">
          <text>📋 复制</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 每日成语 -->
  <view class="daily-section">
    <view class="section-head">
      <view class="section-label-wrap">
        <view class="label-bar"></view>
        <text class="section-label">今日成语</text>
      </view>
      <view class="change-btn" bindtap="changeDailyIdiom" hover-class="btn-hover" hover-stay-time="80">
        <text class="change-text">↺ 换一个</text>
      </view>
    </view>

    <!-- 骨架屏 -->
    <view class="daily-card skeleton-card" wx:if="{{dailyIdiomLoading}}">
      <view class="sk-line sk-w60 sk-h40 sk-mb10"></view>
      <view class="sk-line sk-w40 sk-h24 sk-mb16"></view>
      <view class="sk-line sk-w100 sk-h22 sk-mb8"></view>
      <view class="sk-line sk-w80 sk-h22 sk-mb8"></view>
    </view>

    <!-- 成语卡片 -->
    <view class="daily-card" wx:else>
      <view class="daily-card-bg-char">{{dailyIdiom.word}}</view>
      <view class="daily-top">
        <text class="daily-word">{{dailyIdiom.word}}</text>
        <text class="daily-pinyin">{{dailyIdiom.pinyin}}</text>
        <text class="daily-brief">{{dailyIdiom.brief}}</text>
      </view>
      <view class="daily-sep"></view>
      <view class="daily-story-section" wx:if="{{dailyIdiom.story}}">
        <text class="story-label">📖 典故故事</text>
        <text class="daily-story">{{dailyIdiom.story}}</text>
      </view>
      <view class="daily-extra" wx:if="{{dailyIdiom.origin}}">
        <text class="extra-label">出处</text>
        <text class="extra-text">{{dailyIdiom.origin}}</text>
      </view>
      <view class="daily-tags" wx:if="{{dailyIdiom.synonym || dailyIdiom.antonym}}">
        <view class="tag-item" wx:if="{{dailyIdiom.synonym}}">
          <text class="tag-label">近义：</text>
          <text class="tag-val">{{dailyIdiom.synonym}}</text>
        </view>
        <view class="tag-item" wx:if="{{dailyIdiom.antonym}}">
          <text class="tag-label">反义：</text>
          <text class="tag-val">{{dailyIdiom.antonym}}</text>
        </view>
      </view>
      <view class="daily-actions">
        <view class="daily-action-btn primary-btn" bindtap="lookupDailyIdiom" hover-class="btn-hover" hover-stay-time="80">
          <text>✨ AI深度解析</text>
        </view>
        <view class="daily-action-btn outline-btn" bindtap="toggleDailyFavorite" hover-class="btn-hover" hover-stay-time="80">
          <text>{{isFavorited ? '❤️ 已收藏' : '🤍 收藏'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 分类Tab -->
  <view class="category-section">
    <view class="section-head">
      <view class="section-label-wrap">
        <view class="label-bar"></view>
        <text class="section-label">成语分类</text>
      </view>
    </view>
    <scroll-view scroll-x show-scrollbar="{{false}}" class="cat-scroll" enhanced="{{true}}" bounces="{{false}}">
      <view class="cat-row">
        <view
          class="cat-chip {{activeCategory === item.id ? 'cat-active' : ''}}"
          wx:for="{{idiomCategories}}"
          wx:key="id"
          bindtap="selectCategory"
          data-id="{{item.id}}"
          hover-class="chip-hover"
          hover-stay-time="80"
        >
          <text class="cat-chip-icon">{{item.icon}}</text>
          <text class="cat-chip-name">{{item.name}}</text>
          <text class="cat-chip-count" wx:if="{{item.count}}">{{item.count}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 精选成语故事 -->
  <view class="featured-section">
    <view class="section-head">
      <view class="section-label-wrap">
        <view class="label-bar"></view>
        <text class="section-label">精选故事</text>
      </view>
    </view>
    <view
      class="featured-item"
      wx:for="{{featuredIdioms}}"
      wx:key="id"
      bindtap="lookupFeatured"
      data-word="{{item.word}}"
      hover-class="item-hover"
      hover-stay-time="80"
    >
      <view class="feat-header">
        <view class="feat-word-wrap">
          <text class="feat-word">{{item.word}}</text>
          <text class="feat-pinyin">{{item.pinyin}}</text>
        </view>
        <view class="feat-cat-tag">{{item.category}}</view>
      </view>
      <text class="feat-brief">{{item.brief}}</text>
      <text class="feat-story">{{item.story}}</text>
      <view class="feat-footer">
        <text class="feat-cta">AI深度解析 →</text>
      </view>
    </view>
  </view>

  <!-- 快速查询成语 -->
  <view class="quick-section">
    <view class="section-head">
      <view class="section-label-wrap">
        <view class="label-bar"></view>
        <text class="section-label">快速查询</text>
      </view>
    </view>
    <view class="quick-grid">
      <view
        class="quick-item"
        wx:for="{{knownIdioms}}"
        wx:key="index"
        bindtap="lookupIdiom"
        data-idiom="{{item.word}}"
        hover-class="quick-hover"
        hover-stay-time="80"
      >
        <text class="quick-word">{{item.word}}</text>
        <text class="quick-brief">{{item.brief}}</text>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
