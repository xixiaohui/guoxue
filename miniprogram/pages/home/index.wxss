/* pages/home/index.wxss - 生产级首页样式 v6.0 */

.home-page { background: #FDF6E3; }

/* ── Hero ─────────────────────────────── */
.hero {
  background: linear-gradient(150deg, #5A1200 0%, #8B2500 55%, #A83500 100%);
  padding: 32rpx 30rpx 44rpx;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.hero::after {
  content: '文';
  position: absolute; right: -20rpx; top: -30rpx;
  font-size: 260rpx; color: rgba(255,255,255,.04);
  font-weight: 900; line-height: 1; pointer-events: none;
}

.hero-left {
  width: 96rpx; height: 96rpx;
  background: rgba(255,248,231,.14);
  border: 2rpx solid rgba(255,248,231,.35);
  border-radius: 22rpx;
  display: flex; align-items: center; justify-content: center;
  margin-right: 24rpx; flex-shrink: 0;
}
.hero-logo-char { font-size: 52rpx; color: #FFD97D; font-weight: 700; }

.hero-right { flex: 1; }
.hero-title { display: block; font-size: 40rpx; font-weight: 700; color: #FFF8E7; letter-spacing: 4rpx; }
.hero-sub { display: block; font-size: 22rpx; color: rgba(255,248,231,.65); margin-top: 8rpx; letter-spacing: 2rpx; }

.hero-deco {
  position: absolute; bottom: 14rpx; right: 28rpx;
  font-size: 20rpx; color: rgba(255,248,231,.38); letter-spacing: 4rpx; font-style: italic;
}

/* ── Section ─────────────────────────────── */
.section { margin-top: 28rpx; }

.section-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 24rpx 16rpx;
}

.section-label-wrap { display: flex; align-items: center; gap: 12rpx; }

.label-bar {
  width: 6rpx; height: 30rpx;
  background: linear-gradient(180deg, #C4882E, #8B2500);
  border-radius: 3rpx;
}

.section-label { font-size: 30rpx; font-weight: 600; color: #2C1810; }

.refresh-pill {
  display: flex; align-items: center; gap: 6rpx;
  border: 1rpx solid #C4882E;
  border-radius: 24rpx;
  padding: 6rpx 18rpx;
  background: #FFFBF0;
}
.refresh-icon { font-size: 26rpx; color: #C4882E; }
.refresh-text { font-size: 24rpx; color: #C4882E; }
.pill-hover { background: #FFF0CC !important; }

/* ── 每日经典卡片 ─────────────────────────────── */
.daily-card {
  background: linear-gradient(135deg, #FFFBF0 0%, #FFF5D6 100%);
  border-radius: 20rpx;
  margin: 0 24rpx;
  padding: 32rpx;
  border: 1rpx solid #EDD9A3;
  box-shadow: 0 6rpx 24rpx rgba(139,37,0,.1);
  position: relative; overflow: hidden;
}

.daily-card::before {
  content: '詩';
  position: absolute; right: -10rpx; bottom: -20rpx;
  font-size: 160rpx; color: rgba(196,136,46,.06);
  font-weight: 900; line-height: 1; pointer-events: none;
}

.daily-badge {
  display: inline-block;
  background: linear-gradient(90deg, #C4882E, #8B2500);
  color: #FFF8E7;
  font-size: 20rpx;
  padding: 4rpx 18rpx;
  border-radius: 20rpx;
  margin-bottom: 18rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.card-hover { opacity: 0.9 !important; }

/* 骨架屏 */
.skeleton-card { animation: shimmer 1.5s infinite; }

@keyframes shimmer {
  0% { opacity: 1; } 50% { opacity: .55; } 100% { opacity: 1; }
}

.sk-line { background: #EDD9A3; border-radius: 6rpx; }
.sk-w100 { width: 100%; } .sk-w90 { width: 90%; } .sk-w80 { width: 80%; }
.sk-w60 { width: 60%; } .sk-w40 { width: 40%; }
.sk-h32 { height: 32rpx; } .sk-h22 { height: 22rpx; }
.sk-mb12 { margin-bottom: 12rpx; } .sk-mb20 { margin-bottom: 20rpx; } .sk-mb8 { margin-bottom: 8rpx; }
.sk-divider { height: 1rpx; background: #EDD9A3; margin: 20rpx 0; }

.daily-quote-row { display: flex; align-items: flex-start; margin-bottom: 16rpx; }
.q-mark { font-size: 46rpx; color: #C4882E; line-height: 1; font-weight: 700; }
.q-mark:first-child { margin-right: 6rpx; margin-top: -4rpx; }
.q-mark:last-child { margin-left: 6rpx; align-self: flex-end; }

.daily-quote {
  flex: 1; font-size: 30rpx; color: #2C1810;
  line-height: 1.85; font-weight: 500;
}

.daily-author {
  display: block; font-size: 22rpx; color: #8C7B61;
  text-align: right; margin-bottom: 16rpx; font-style: italic;
}

.daily-sep {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #C4882E, transparent);
  margin: 14rpx 0;
}

.daily-translation {
  display: block; font-size: 26rpx; color: #5A4030;
  line-height: 1.8; margin-bottom: 16rpx;
}

.daily-insight-box {
  background: rgba(196,136,46,.08);
  border-left: 4rpx solid #C4882E;
  border-radius: 0 10rpx 10rpx 0;
  padding: 14rpx 18rpx;
  display: flex; align-items: flex-start; gap: 10rpx;
}
.insight-dot { font-size: 20rpx; color: #C4882E; flex-shrink: 0; margin-top: 4rpx; }
.insight-text { font-size: 25rpx; color: #4A3020; line-height: 1.7; }

.daily-footer { margin-top: 18rpx; text-align: right; }
.daily-cta { font-size: 22rpx; color: #C4882E; }

/* ── 功能网格（5宫格，3+2布局） ─────────────────────────────── */
.func-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
  padding: 0 24rpx;
}

/* 若只有5个item，第5个独立占一格留中 */
.func-item:last-child:nth-child(3n+2) {
  grid-column: 2;
}

.func-item {
  background: #FFFBF0;
  border-radius: 18rpx;
  padding: 24rpx 12rpx;
  text-align: center;
  border: 1rpx solid #EDD9A3;
  box-shadow: 0 2rpx 10rpx rgba(139,37,0,.05);
  display: flex; flex-direction: column; align-items: center;
  transition: transform 0.1s;
}
.func-hover { opacity: 0.85 !important; transform: scale(.96) !important; }

.func-icon {
  width: 90rpx; height: 90rpx;
  border-radius: 24rpx;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 14rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,.12);
}
.func-char { font-size: 46rpx; color: #fff; font-weight: 700; }
.func-name { font-size: 27rpx; color: #2C1810; font-weight: 500; margin-bottom: 4rpx; }
.func-desc { font-size: 20rpx; color: #8C7B61; }

/* ── 热门话题 ─────────────────────────────── */
.hot-scroll { padding: 0 24rpx; white-space: nowrap; }
.hot-row { display: inline-flex; gap: 14rpx; padding-bottom: 12rpx; }

.hot-chip {
  display: inline-flex; align-items: center; gap: 8rpx;
  background: #FFFBF0;
  border: 1rpx solid #EDD9A3;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
  font-size: 25rpx; color: #4A3020;
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(196,136,46,.1);
}
.hot-hover { background: #FFF0CC !important; }
.hot-fire { font-size: 24rpx; }

/* ── 分类列表 ─────────────────────────────── */
.cat-list { padding: 0 24rpx; }

.cat-row {
  display: flex; align-items: center;
  background: #FFFBF0;
  border-radius: 16rpx;
  padding: 20rpx 18rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid #EDD9A3;
  box-shadow: 0 2rpx 8rpx rgba(139,37,0,.04);
}
.cat-row-hover { background: #FFF5DC !important; }

.cat-icon-wrap {
  width: 76rpx; height: 76rpx;
  border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
  margin-right: 18rpx; flex-shrink: 0;
}
.cat-icon { font-size: 38rpx; }
.cat-info { flex: 1; }
.cat-name { display: block; font-size: 29rpx; color: #2C1810; font-weight: 500; }
.cat-desc { display: block; font-size: 22rpx; color: #8C7B61; margin-top: 4rpx; }
.cat-arr { font-size: 40rpx; color: #C4882E; font-weight: 300; }

/* ── 底部 ─────────────────────────────── */
.home-footer { padding: 36rpx 0 20rpx; text-align: center; }
.footer-txt { font-size: 22rpx; color: #B09070; letter-spacing: 2rpx; }
.safe-bottom { height: env(safe-area-inset-bottom); }

/* ── VIP推介条 ─────────────────────────────── */
.vip-banner {
  margin: 0 20rpx 20rpx;
  background: linear-gradient(90deg, #5A0A00, #8B2500 60%, #C4882E);
  border-radius: 20rpx;
  padding: 22rpx 28rpx;
  display: flex; align-items: center; justify-content: space-between;
  box-shadow: 0 6rpx 20rpx rgba(139,37,0,.25);
}
.vip-hover { opacity: 0.9 !important; }
.vip-banner-left { display: flex; align-items: center; gap: 16rpx; }
.vip-banner-crown { font-size: 40rpx; }
.vip-banner-title { display: block; font-size: 28rpx; font-weight: bold; color: #FFF8E7; }
.vip-banner-sub { display: block; font-size: 22rpx; color: rgba(255,248,231,.7); margin-top: 4rpx; }
.vip-banner-right { display: flex; align-items: center; gap: 8rpx; }
.vip-banner-price { font-size: 28rpx; color: #F7C948; font-weight: bold; }
.vip-banner-arrow { font-size: 40rpx; color: #F7C948; }

/* ── 首页广告位 ─────────────────────────────── */
.home-ad { margin: 10rpx 20rpx 0; border-radius: 16rpx; overflow: hidden; }
