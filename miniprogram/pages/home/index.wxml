<!-- pages/home/index.wxml - 生产级首页 -->
<view class="home-page">

  <!-- Hero Banner -->
  <view class="hero">
    <view class="hero-left">
      <text class="hero-logo-char">文</text>
    </view>
    <view class="hero-right">
      <text class="hero-title">国学AI助手</text>
      <text class="hero-sub">传承千年智慧 · 探索文化精髓</text>
    </view>
    <view class="hero-deco">道可道，非常道</view>
  </view>

  <!-- 每日经典 -->
  <view class="section">
    <view class="section-head">
      <view class="section-label-wrap">
        <view class="label-bar"></view>
        <text class="section-label">今日经典</text>
      </view>
      <view class="refresh-pill" bindtap="refreshDaily">
        <text class="refresh-icon">↺</text>
        <text class="refresh-text">换一条</text>
      </view>
    </view>

    <!-- 骨架屏 -->
    <view class="daily-card skeleton-card" wx:if="{{dailyLoading}}">
      <view class="sk-line sk-w80 sk-h32 sk-mb12"></view>
      <view class="sk-line sk-w40 sk-h22 sk-mb20"></view>
      <view class="sk-divider"></view>
      <view class="sk-line sk-w100 sk-h22 sk-mb8"></view>
      <view class="sk-line sk-w90 sk-h22 sk-mb8"></view>
      <view class="sk-line sk-w60 sk-h22"></view>
    </view>

    <!-- 实际内容 -->
    <view class="daily-card" wx:else bindtap="goDiscussDaily">
      <view class="daily-quote-row">
        <text class="q-mark">「</text>
        <text class="daily-quote">{{daily.quote}}</text>
        <text class="q-mark">」</text>
      </view>
      <text class="daily-author" wx:if="{{daily.author}}">—— {{daily.author}}</text>

      <view class="daily-sep"></view>

      <text class="daily-translation" wx:if="{{daily.translation}}">{{daily.translation}}</text>

      <view class="daily-insight-box" wx:if="{{daily.insight}}">
        <text class="insight-dot">◆</text>
        <text class="insight-text">{{daily.insight}}</text>
      </view>

      <view class="daily-footer">
        <text class="daily-cta">与文渊先生深入探讨 →</text>
      </view>
    </view>
  </view>

  <!-- 功能导航 -->
  <view class="section">
    <view class="section-head">
      <view class="section-label-wrap">
        <view class="label-bar"></view>
        <text class="section-label">功能导航</text>
      </view>
    </view>
    <view class="func-grid">
      <view class="func-item" bindtap="goToChat" hover-class="func-hover" hover-stay-time="100">
        <view class="func-icon" style="background:linear-gradient(135deg,#FF8C5C,#C44020)">
          <text class="func-char">問</text>
        </view>
        <text class="func-name">AI问答</text>
        <text class="func-desc">智能国学问答</text>
      </view>
      <view class="func-item" bindtap="goTranslate" hover-class="func-hover" hover-stay-time="100">
        <view class="func-icon" style="background:linear-gradient(135deg,#52C8A0,#1A8060)">
          <text class="func-char">译</text>
        </view>
        <text class="func-name">古文翻译</text>
        <text class="func-desc">文言白话互译</text>
      </view>
      <view class="func-item" bindtap="goCategory" data-cat="{{categories[0]}}" hover-class="func-hover" hover-stay-time="100">
        <view class="func-icon" style="background:linear-gradient(135deg,#9B6FD5,#6A3DA8)">
          <text class="func-char">詩</text>
        </view>
        <text class="func-name">诗词典籍</text>
        <text class="func-desc">经典赏析</text>
      </view>
      <view class="func-item" bindtap="goCategory" data-cat="{{categories[2]}}" hover-class="func-hover" hover-stay-time="100">
        <view class="func-icon" style="background:linear-gradient(135deg,#F0B840,#C48A10)">
          <text class="func-char">成</text>
        </view>
        <text class="func-name">成语故事</text>
        <text class="func-desc">典故解析</text>
      </view>
      <view class="func-item" bindtap="goCategory" data-cat="{{categories[3]}}" hover-class="func-hover" hover-stay-time="100">
        <view class="func-icon" style="background:linear-gradient(135deg,#5BC8F5,#1A7ED5)">
          <text class="func-char">史</text>
        </view>
        <text class="func-name">历史探秘</text>
        <text class="func-desc">朝代人物</text>
      </view>
      <view class="func-item" bindtap="goCategory" data-cat="{{categories[4]}}" hover-class="func-hover" hover-stay-time="100">
        <view class="func-icon" style="background:linear-gradient(135deg,#FF8FA3,#C03060)">
          <text class="func-char">道</text>
        </view>
        <text class="func-name">诸子百家</text>
        <text class="func-desc">百家争鸣</text>
      </view>
    </view>
  </view>

  <!-- 热门话题 -->
  <view class="section">
    <view class="section-head">
      <view class="section-label-wrap">
        <view class="label-bar"></view>
        <text class="section-label">热门话题</text>
      </view>
    </view>
    <scroll-view scroll-x show-scrollbar="{{false}}" class="hot-scroll">
      <view class="hot-row">
        <view
          class="hot-chip"
          wx:for="{{hotTopics}}"
          wx:key="index"
          bindtap="goHotTopic"
          data-topic="{{item}}"
          hover-class="hot-hover"
          hover-stay-time="80"
        >
          <text class="hot-fire">🔥</text>
          <text class="hot-text">{{item}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 国学分类（前插入VIP推介条） -->
  <!-- VIP推介条 -->
  <view class="vip-banner" bindtap="goVip">
    <view class="vip-banner-left">
      <text class="vip-banner-crown">👑</text>
      <view>
        <text class="vip-banner-title">升级会员 · 无限畅用</text>
        <text class="vip-banner-sub">去广告 · 无限AI · 语音朗读</text>
      </view>
    </view>
    <view class="vip-banner-right">
      <text class="vip-banner-price">9.9元/月</text>
      <text class="vip-banner-arrow">›</text>
    </view>
  </view>

  <!-- 国学分类 -->
  <view class="section">
    <view class="section-head">
      <view class="section-label-wrap">
        <view class="label-bar"></view>
        <text class="section-label">国学分类</text>
      </view>
    </view>
    <view class="cat-list">
      <view
        class="cat-row"
        wx:for="{{categories}}"
        wx:key="id"
        bindtap="goCategory"
        data-cat="{{item}}"
        hover-class="cat-row-hover"
        hover-stay-time="100"
      >
        <view class="cat-icon-wrap" style="background:{{item.bg}}">
          <text class="cat-icon">{{item.icon}}</text>
        </view>
        <view class="cat-info">
          <text class="cat-name">{{item.name}}</text>
          <text class="cat-desc">{{item.desc}}</text>
        </view>
        <text class="cat-arr">›</text>
      </view>
    </view>
  </view>

  <!-- 底部 -->
  <view class="home-footer">
    <text class="footer-txt">传承国学精髓 · AI赋能学习</text>
  </view>

  <!-- 原生广告（嵌入首页底部，VIP时可隐藏） -->
  <ad
    unit-id="adunit-513a37c7d48cdf7f"
    ad-type="native"
    native-ad-template="large"
    class="home-ad"
    binderror="onAdError"
  ></ad>

  <view class="safe-bottom"></view>
</view>
