<!-- pages/home/index.wxml - 生产级首页 v7.0（换一条优化 + 分享海报）-->
<view class="home-page">

  <!-- Hero Banner -->
  <view class="hero">
    <view class="hero-left">
      <text class="hero-logo-char">文</text>
    </view>
    <view class="hero-right">
      <text class="hero-title">国学助手</text>
      <text class="hero-sub">传承千年智慧 · 探索文化精髓</text>
    </view>
    <view class="hero-deco">道可道，非常道</view>
  </view>

  <!-- 每日经典 -->
  <view class="section">
    <view class="section-head">
      <view class="section-label-wrap">
        <view class="label-bar"></view>
        <text class="section-label">今日经典</text>
      </view>
      <view class="head-actions">
        <!-- 换一条按钮 -->
        <view
          class="refresh-pill {{refreshing ? 'pill-spinning' : ''}}"
          bindtap="refreshDaily"
          hover-class="pill-hover"
          hover-stay-time="80"
        >
          <text class="refresh-icon">↺</text>
          <text class="refresh-text">换一条</text>
        </view>
        <!-- 分享按钮 -->
        <view
          class="share-pill"
          bindtap="showShareMenu"
          hover-class="pill-hover"
          hover-stay-time="80"
        >
          <text class="share-icon">↑</text>
          <text class="share-text">分享</text>
        </view>
      </view>
    </view>

    <!-- 骨架屏 -->
    <view class="daily-card skeleton-card" wx:if="{{dailyLoading}}">
      <view class="sk-line sk-w80 sk-h32 sk-mb12"></view>
      <view class="sk-line sk-w40 sk-h22 sk-mb20"></view>
      <view class="sk-divider"></view>
      <view class="sk-line sk-w100 sk-h22 sk-mb8"></view>
      <view class="sk-line sk-w90 sk-h22 sk-mb8"></view>
      <view class="sk-line sk-w60 sk-h22"></view>
    </view>

    <!-- 实际内容 -->
    <view
      class="daily-card {{refreshing ? 'card-fade' : ''}}"
      wx:else
      bindtap="goDiscussDaily"
      hover-class="card-hover"
      hover-stay-time="100"
    >
      <view class="daily-badge">今日名句</view>
      <view class="daily-quote-row">
        <text class="q-mark">「</text>
        <text class="daily-quote">{{daily.quote}}</text>
        <text class="q-mark">」</text>
      </view>
      <text class="daily-author" wx:if="{{daily.author}}">—— {{daily.author}}</text>

      <view class="daily-sep"></view>

      <text class="daily-translation" wx:if="{{daily.translation}}">{{daily.translation}}</text>

      <view class="daily-insight-box" wx:if="{{daily.insight}}">
        <text class="insight-dot">◆</text>
        <text class="insight-text">{{daily.insight}}</text>
      </view>

      <view class="daily-footer">
        <text class="daily-cta">点击进入古文翻译深度赏析 →</text>
        <view class="daily-share-hint" catchtap="showShareMenu">
          <text class="hint-icon">↑</text>
          <text class="hint-txt">分享</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 五大功能导航 -->
  <view class="section">
    <view class="section-head">
      <view class="section-label-wrap">
        <view class="label-bar"></view>
        <text class="section-label">功能导航</text>
      </view>
    </view>
    <view class="func-grid">
      <view
        class="func-item"
        wx:for="{{funcs}}"
        wx:key="id"
        bindtap="goFunc"
        data-func="{{item}}"
        hover-class="func-hover"
        hover-stay-time="100"
      >
        <view class="func-icon" style="background:{{item.bg}}">
          <text class="func-char">{{item.char}}</text>
        </view>
        <text class="func-name">{{item.name}}</text>
        <text class="func-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 热门话题 -->
  <view class="section">
    <view class="section-head">
      <view class="section-label-wrap">
        <view class="label-bar"></view>
        <text class="section-label">热门话题</text>
      </view>
    </view>
    <scroll-view scroll-x show-scrollbar="{{false}}" class="hot-scroll" enhanced="{{true}}" bounces="{{false}}">
      <view class="hot-row">
        <view
          class="hot-chip"
          wx:for="{{hotTopics}}"
          wx:key="index"
          bindtap="goHotTopic"
          data-topic="{{item.text}}"
          data-page="{{item.page}}"
          hover-class="hot-hover"
          hover-stay-time="80"
        >
          <text class="hot-fire">🔥</text>
          <text class="hot-text">{{item.text}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- VIP推介条 -->
  <view class="vip-banner" bindtap="goVip" hover-class="vip-hover" hover-stay-time="100">
    <view class="vip-banner-left">
      <text class="vip-banner-crown">👑</text>
      <view>
        <text class="vip-banner-title">升级会员 · 无限畅用</text>
        <text class="vip-banner-sub">去广告 · 无限AI · 专属内容</text>
      </view>
    </view>
    <view class="vip-banner-right">
      <text class="vip-banner-price">9.9元/月</text>
      <text class="vip-banner-arrow">›</text>
    </view>
  </view>

  <!-- 国学分类 -->
  <view class="section">
    <view class="section-head">
      <view class="section-label-wrap">
        <view class="label-bar"></view>
        <text class="section-label">国学分类</text>
      </view>
    </view>
    <view class="cat-list">
      <view
        class="cat-row"
        wx:for="{{categories}}"
        wx:key="id"
        bindtap="goCategory"
        data-cat="{{item}}"
        hover-class="cat-row-hover"
        hover-stay-time="100"
      >
        <view class="cat-icon-wrap" style="background:{{item.bg}}">
          <text class="cat-icon">{{item.icon}}</text>
        </view>
        <view class="cat-info">
          <text class="cat-name">{{item.name}}</text>
          <text class="cat-desc">{{item.desc}}</text>
        </view>
        <text class="cat-arr">›</text>
      </view>
    </view>
  </view>

  <!-- 底部 -->
  <view class="home-footer">
    <text class="footer-txt">传承国学精髓 · 智慧赋能人生</text>
  </view>

  <!-- 原生广告 -->
  <ad
    unit-id="adunit-513a37c7d48cdf7f"
    ad-type="native"
    native-ad-template="large"
    class="home-ad"
    binderror="onAdError"
  ></ad>

  <view class="safe-bottom"></view>
</view>

<!-- ── 海报弹窗 ──────────────────────────────── -->
<view class="poster-mask" wx:if="{{showPoster}}" bindtap="closePoster">
  <view class="poster-container" catchtap="">

    <!-- 关闭按钮 -->
    <view class="poster-close" bindtap="closePoster">✕</view>

    <view class="poster-title">精美海报</view>
    <view class="poster-sub">长按图片保存或识别小程序码</view>

    <!-- Canvas（用于绘制海报，设计尺寸 750×1200 → 展示按比例缩放）-->
    <view class="poster-canvas-wrap">
      <!-- 加载中占位 -->
      <view class="poster-loading" wx:if="{{posterLoading}}">
        <view class="poster-loading-spin">⟳</view>
        <text class="poster-loading-txt">海报绘制中...</text>
      </view>
      <!-- Canvas 节点（始终存在） -->
      <canvas
        id="posterCanvas"
        type="2d"
        class="poster-canvas"
        style="width:750rpx;height:1200rpx;"
      ></canvas>
      <!-- 生成后的预览图（覆盖在 canvas 上，供长按保存）-->
      <image
        wx:if="{{posterPath}}"
        class="poster-preview"
        src="{{posterPath}}"
        mode="widthFix"
        show-menu-by-longpress="{{true}}"
        bindlongpress="savePoster"
      ></image>
    </view>

    <!-- 操作按钮 -->
    <view class="poster-actions" wx:if="{{posterPath}}">
      <view class="poster-btn poster-btn-save" bindtap="savePoster" hover-class="btn-hover" hover-stay-time="80">
        <text>💾 保存到相册</text>
      </view>
      <view class="poster-btn poster-btn-share" bindtap="onShareAppMessage" hover-class="btn-hover" hover-stay-time="80">
        <button open-type="share" class="poster-share-inner">
          <text>📤 发送给好友</text>
        </button>
      </view>
    </view>

    <view class="poster-hint" wx:if="{{posterPath}}">长按图片可直接保存</view>
  </view>
</view>
