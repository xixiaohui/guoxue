/* pages/philosophers/index.wxss - 诸子百家样式 v6.0 */

.philosophers-page { background: #FDF6E3; min-height: 100vh; }

/* ── 页头 ─────────────────────────────── */
.page-header {
  background: linear-gradient(160deg, #3A0A50 0%, #6B1A8A 55%, #8B2FA0 100%);
  padding: 32rpx 30rpx 44rpx;
  position: relative; overflow: hidden;
  display: flex; flex-direction: column;
}
.header-deco-char {
  position: absolute; right: -10rpx; top: -20rpx;
  font-size: 280rpx; color: rgba(255,255,255,.04);
  font-weight: 900; line-height: 1; pointer-events: none;
}
.header-inner { margin-bottom: 20rpx; }
.header-title { display: block; font-size: 42rpx; font-weight: 700; color: #FFF8E7; letter-spacing: 4rpx; }
.header-sub { display: block; font-size: 24rpx; color: rgba(255,248,231,.6); margin-top: 8rpx; letter-spacing: 3rpx; }
.header-stats { display: flex; gap: 40rpx; }
.stat-item { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.stat-num { font-size: 40rpx; font-weight: 700; color: #F7C948; }
.stat-label { font-size: 20rpx; color: rgba(255,248,231,.7); }

/* ── 搜索栏 ─────────────────────────────── */
.search-bar {
  margin: -20rpx 24rpx 0;
  background: #FFFBF0;
  border-radius: 20rpx;
  padding: 12rpx 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(107,26,138,.2);
  border: 1rpx solid #D4A8F0;
}
.search-inner { display: flex; align-items: center; gap: 10rpx; }
.search-icon { font-size: 28rpx; flex-shrink: 0; }
.search-input { flex: 1; font-size: 26rpx; color: #2C1810; height: 56rpx; }
.search-placeholder { color: #B09070; font-size: 24rpx; }
.search-btn {
  background: linear-gradient(90deg, #6B1A8A, #8B2FA0);
  border-radius: 20rpx; padding: 8rpx 24rpx;
}
.search-btn-hover { opacity: 0.8 !important; }
.search-btn-text { font-size: 24rpx; color: #FFF8E7; font-weight: 500; }

/* ── AI解析结果 ─────────────────────────────── */
.ai-result-section {
  background: #FFFBF0;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  border: 1rpx solid #6B1A8A;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(107,26,138,.15);
}
.result-header {
  background: linear-gradient(90deg, #3A0A50, #8B2FA0);
  padding: 16rpx 20rpx;
  display: flex; align-items: center; justify-content: space-between;
}
.result-title-row { display: flex; align-items: center; gap: 10rpx; flex: 1; overflow: hidden; }
.result-dot { width: 10rpx; height: 10rpx; background: #F7C948; border-radius: 50%; flex-shrink: 0; }
.result-title { font-size: 24rpx; color: #FFF8E7; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.result-actions { display: flex; gap: 12rpx; flex-shrink: 0; }
.action-btn {
  background: rgba(255,255,255,.2); border-radius: 20rpx;
  padding: 6rpx 16rpx; font-size: 24rpx; color: #FFF8E7;
}
.action-hover { background: rgba(255,255,255,.35) !important; }
.result-loading { display: flex; flex-direction: column; align-items: center; padding: 40rpx; gap: 16rpx; }
.ai-loading-icon { font-size: 56rpx; animation: swing 1.5s infinite; }
@keyframes swing { 0%,100% { transform: rotate(-8deg); } 50% { transform: rotate(8deg); } }
.ai-loading-text { font-size: 24rpx; color: #8C7B61; }
.result-body { padding: 24rpx; }
.seg-block { margin-bottom: 20rpx; }
.seg-label-row { display: flex; align-items: center; gap: 10rpx; margin-bottom: 8rpx; }
.seg-dot { width: 8rpx; height: 28rpx; background: linear-gradient(180deg, #8B2FA0, #6B1A8A); border-radius: 4rpx; }
.seg-label { font-size: 26rpx; font-weight: 600; color: #6B1A8A; }
.seg-content { font-size: 26rpx; color: #2C1810; line-height: 1.9; padding-left: 18rpx; white-space: pre-wrap; }

/* ── 学派总览 ─────────────────────────────── */
.schools-section { margin-top: 28rpx; }
.section-head { display: flex; align-items: center; justify-content: space-between; padding: 0 24rpx 16rpx; }
.section-label-wrap { display: flex; align-items: center; gap: 12rpx; }
.label-bar { width: 6rpx; height: 30rpx; background: linear-gradient(180deg, #8B2FA0, #6B1A8A); border-radius: 3rpx; }
.section-label { font-size: 30rpx; font-weight: 600; color: #2C1810; }

.schools-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; padding: 0 24rpx; }
.school-card {
  background: #FFFBF0;
  border-radius: 20rpx;
  border: 1rpx solid #EDD9A3;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(107,26,138,.08);
}
.school-hover { opacity: 0.88 !important; transform: scale(.98); }
.school-header {
  padding: 20rpx 18rpx;
  display: flex; flex-direction: column; align-items: center;
  text-align: center;
}
.school-emoji { font-size: 40rpx; margin-bottom: 8rpx; }
.school-name { display: block; font-size: 32rpx; font-weight: 700; color: #FFF8E7; }
.school-period { display: block; font-size: 19rpx; color: rgba(255,248,231,.75); margin-top: 4rpx; }
.school-body { padding: 16rpx; }
.school-core {
  display: block; font-size: 22rpx; color: #6B1A8A; font-weight: 600;
  background: #F0E0FF; padding: 4rpx 12rpx; border-radius: 10rpx;
  margin-bottom: 10rpx;
}
.school-desc { display: block; font-size: 22rpx; color: #4A3020; line-height: 1.7; margin-bottom: 12rpx; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; }
.school-works { display: flex; flex-wrap: wrap; gap: 6rpx; margin-bottom: 10rpx; }
.work-tag { font-size: 18rpx; color: #6B1A8A; background: #F0E0FF; padding: 2rpx 10rpx; border-radius: 8rpx; }
.school-cta { font-size: 20rpx; color: #8B2FA0; }

/* ── 诸子名言 ─────────────────────────────── */
.quotes-section { margin-top: 28rpx; }
.quotes-scroll { padding: 0 24rpx; white-space: nowrap; }
.quotes-row { display: inline-flex; gap: 16rpx; padding-bottom: 8rpx; }
.quote-card {
  width: 300rpx;
  background: #FFFBF0;
  border-radius: 20rpx;
  border: 1rpx solid #EDD9A3;
  padding: 20rpx;
  display: inline-flex; flex-direction: column; gap: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(107,26,138,.06);
}
.quote-hover { background: #F5EDFF !important; }
.quote-school-badge {
  width: 40rpx; height: 40rpx;
  border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 20rpx; color: #FFF8E7; font-weight: 700;
  align-self: flex-start;
}
.quote-text { font-size: 24rpx; color: #2C1810; line-height: 1.8; white-space: normal; font-style: italic; }
.quote-author { font-size: 20rpx; color: #8C7B61; text-align: right; }

/* ── 四家思想对比 ─────────────────────────────── */
.compare-section { margin-top: 28rpx; }
.compare-table {
  margin: 0 24rpx;
  background: #FFFBF0;
  border-radius: 20rpx;
  border: 1rpx solid #EDD9A3;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(107,26,138,.06);
}
.compare-header {
  display: flex;
  background: linear-gradient(90deg, #3A0A50, #8B2FA0);
}
.compare-row { display: flex; border-top: 1rpx solid #F0E0FF; }
.compare-row:nth-child(even) { background: #FAF0FF; }
.compare-cell {
  flex: 1; padding: 14rpx 10rpx;
  font-size: 21rpx; color: #2C1810;
  text-align: center; line-height: 1.5;
}
.compare-head-cell { color: #FFF8E7; font-weight: 600; }
.aspect-col { flex: 1.2; font-weight: 600; color: #4A3020; background: rgba(240,224,255,.3); }
.ru-cell { color: #E05820; }
.dao-cell { color: #38F9D7; }
.fa-cell { color: #6B5BB5; }
.mo-cell { color: #1A9ED5; }

/* ── 弹窗 ─────────────────────────────── */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,.55);
  display: flex; align-items: flex-end;
  z-index: 100;
}
.modal-box {
  background: #FFFBF0;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 85vh;
  display: flex; flex-direction: column;
  overflow: hidden;
}
.modal-header {
  padding: 28rpx 28rpx 20rpx;
  display: flex; align-items: center; justify-content: space-between;
  flex-shrink: 0;
}
.modal-header-inner { display: flex; align-items: center; gap: 20rpx; }
.modal-emoji { font-size: 50rpx; }
.modal-school-name { display: block; font-size: 38rpx; font-weight: 700; color: #FFF8E7; }
.modal-school-sub { display: block; font-size: 20rpx; color: rgba(255,248,231,.7); margin-top: 4rpx; }
.modal-close {
  width: 56rpx; height: 56rpx;
  background: rgba(255,255,255,.2);
  border-radius: 28rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #FFF8E7; flex-shrink: 0;
}
.close-hover { background: rgba(255,255,255,.35) !important; }
.modal-body { flex: 1; padding: 24rpx 28rpx; overflow: hidden; }
.modal-section { margin-bottom: 24rpx; }
.modal-section-title { display: block; font-size: 26rpx; font-weight: 600; color: #6B1A8A; margin-bottom: 12rpx; }
.modal-core-badge {
  display: inline-block;
  background: linear-gradient(90deg, #6B1A8A, #8B2FA0);
  color: #FFF8E7; font-size: 26rpx; font-weight: 600;
  padding: 6rpx 20rpx; border-radius: 20rpx; margin-bottom: 12rpx;
}
.modal-desc { display: block; font-size: 26rpx; color: #2C1810; line-height: 1.8; }
.works-wrap, .reps-wrap { display: flex; flex-wrap: wrap; gap: 10rpx; }
.work-chip {
  background: #F0E0FF; color: #6B1A8A;
  font-size: 22rpx; padding: 6rpx 16rpx;
  border-radius: 14rpx; border: 1rpx solid #D4A8F0;
}
.rep-chip {
  background: #FFF0E0; color: #8B2500;
  font-size: 22rpx; padding: 6rpx 16rpx;
  border-radius: 14rpx; border: 1rpx solid #F0C890;
}
.modal-quotes { display: flex; flex-direction: column; gap: 14rpx; }
.modal-quote-item { background: #FAF0FF; border-radius: 12rpx; padding: 14rpx 16rpx; border-left: 4rpx solid #6B1A8A; }
.modal-quote-text { display: block; font-size: 26rpx; color: #2C1810; line-height: 1.8; font-style: italic; margin-bottom: 6rpx; }
.modal-quote-src { font-size: 20rpx; color: #8C7B61; text-align: right; display: block; }
.modal-actions {
  display: flex; gap: 16rpx;
  padding: 16rpx 28rpx;
  border-top: 1rpx solid #EDD9A3;
  flex-shrink: 0;
}
.btn-hover { opacity: 0.8 !important; }
.modal-close-btn {
  flex: 1; height: 80rpx; border: 2rpx solid #6B1A8A;
  border-radius: 40rpx; display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; color: #6B1A8A;
}
.modal-analyze-btn {
  flex: 2; height: 80rpx;
  background: linear-gradient(90deg, #6B1A8A, #8B2FA0);
  border-radius: 40rpx; display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; color: #FFF8E7; font-weight: 500;
}

/* ── 底部 ─────────────────────────────── */
.home-footer { padding: 36rpx 0 20rpx; text-align: center; }
.footer-txt { font-size: 22rpx; color: #B09070; letter-spacing: 2rpx; }
.safe-bottom { height: env(safe-area-inset-bottom); min-height: 40rpx; }
