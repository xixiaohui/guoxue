/* pages/history/index.wxss - 历史探秘页样式 */

.history-page {
  background: #FDF6E3;
}

/* 头部 */
.history-header {
  background: linear-gradient(160deg, #1A0A00, #4A1800, #6B2800);
  padding: 24rpx 24rpx 32rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #FFF8E7;
  letter-spacing: 8rpx;
  text-align: center;
}

.header-sub {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 248, 231, 0.6);
  letter-spacing: 4rpx;
  text-align: center;
  margin: 8rpx 0 20rpx;
}

.search-row {
  display: flex;
  align-items: center;
  background: rgba(255, 248, 231, 0.12);
  border: 1rpx solid rgba(255, 248, 231, 0.25);
  border-radius: 40rpx;
  overflow: hidden;
  padding: 0 8rpx 0 24rpx;
}

.hist-search {
  flex: 1;
  font-size: 28rpx;
  color: #FFF8E7;
  min-height: 72rpx;
}

.hist-ph {
  color: rgba(255, 248, 231, 0.45);
}

.hist-search-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(196, 136, 46, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

/* 朝代导航 */
.dynasty-nav {
  background: #FFFBF0;
  border-bottom: 1rpx solid #E8D5A3;
  white-space: nowrap;
}

.dynasty-list {
  display: flex;
  padding: 0 16rpx;
}

.dynasty-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
  white-space: nowrap;
  border-bottom: 4rpx solid transparent;
  transition: all 0.2s;
}

.dynasty-item.active {
  border-bottom-color: #8B2500;
}

.dynasty-name {
  font-size: 26rpx;
  color: #6B5B45;
  font-weight: 500;
}

.dynasty-item.active .dynasty-name {
  color: #8B2500;
  font-weight: 600;
}

.dynasty-years {
  font-size: 18rpx;
  color: #B09070;
  margin-top: 2rpx;
}

/* AI结果 */
.ai-result-section {
  background: #FFFBF0;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #EDD9A3;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(139, 37, 0, 0.08);
}

.ai-result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(74, 24, 0, 0.08);
  border-bottom: 1rpx solid #EDD9A3;
}

.ai-label {
  font-size: 28rpx;
  color: #8B2500;
  font-weight: 600;
}

.close-result {
  font-size: 32rpx;
  color: #8C7B61;
  padding: 4rpx 12rpx;
}

.result-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  gap: 16rpx;
}

.loading-hint {
  font-size: 26rpx;
  color: #8C7B61;
}

.ai-result-content {
  padding: 24rpx;
}

.ai-result-text {
  font-size: 28rpx;
  color: #2C1810;
  line-height: 1.9;
  white-space: pre-wrap;
}

.result-btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.result-action-btn {
  flex: 1;
  background: rgba(139, 37, 0, 0.06);
  border: 1rpx solid #C4882E;
  border-radius: 32rpx;
  padding: 14rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8B2500;
}

/* 时间轴 */
.timeline-section {
  padding: 0 0 20rpx;
}

.timeline {
  padding: 8rpx 24rpx;
}

.timeline-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 0;
}

.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 24rpx;
  padding-top: 16rpx;
}

.time-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(196, 136, 46, 0.2);
}

.time-line {
  width: 2rpx;
  flex: 1;
  min-height: 40rpx;
  background: linear-gradient(180deg, #E8D5A3, transparent);
  margin: 8rpx 0;
}

.timeline-content {
  flex: 1;
  background: #FFFBF0;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #EDD9A3;
  box-shadow: 0 2rpx 8rpx rgba(139, 37, 0, 0.04);
}

.timeline-item:active .timeline-content {
  background: #FFF5DC;
}

.event-year {
  display: block;
  font-size: 22rpx;
  color: #C4882E;
  margin-bottom: 8rpx;
}

.event-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2C1810;
  margin-bottom: 8rpx;
}

.event-desc {
  display: block;
  font-size: 26rpx;
  color: #5A4030;
  line-height: 1.6;
}

.event-figures {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.figure-tag {
  background: #FFF3DC;
  color: #8B2500;
  border: 1rpx solid #E8C88A;
  border-radius: 12rpx;
  padding: 4rpx 14rpx;
  font-size: 22rpx;
}

/* 名人殿堂 */
.figures-section {
  margin-top: 32rpx;
}

.figures-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 8rpx 24rpx;
}

.figure-card {
  background: #FFFBF0;
  border-radius: 16rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  border: 1rpx solid #EDD9A3;
  box-shadow: 0 2rpx 8rpx rgba(139, 37, 0, 0.04);
}

.figure-card:active {
  background: #FFF5DC;
}

.figure-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 12rpx;
}

.figure-emoji {
  font-size: 36rpx;
}

.figure-name {
  display: block;
  font-size: 28rpx;
  color: #2C1810;
  font-weight: 600;
}

.figure-dynasty {
  display: block;
  font-size: 20rpx;
  color: #C4882E;
  margin-top: 4rpx;
}

.figure-role {
  display: block;
  font-size: 20rpx;
  color: #8C7B61;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 趣闻 */
.trivia-section {
  margin-top: 32rpx;
  padding-bottom: 40rpx;
}

.trivia-list {
  padding: 8rpx 24rpx;
}

.trivia-item {
  display: flex;
  align-items: center;
  background: #FFFBF0;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #EDD9A3;
  box-shadow: 0 2rpx 8rpx rgba(139, 37, 0, 0.04);
}

.trivia-item:active {
  background: #FFF5DC;
}

.trivia-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.trivia-info {
  flex: 1;
}

.trivia-title {
  display: block;
  font-size: 30rpx;
  color: #2C1810;
  font-weight: 500;
}

.trivia-hint {
  display: block;
  font-size: 24rpx;
  color: #8C7B61;
  margin-top: 6rpx;
}

.trivia-arrow {
  font-size: 40rpx;
  color: #C4882E;
}

/* ── Hover 状态 & 新增 ─────────────────────────────── */
.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2C1810;
  padding: 16rpx 24rpx 8rpx;
}
.dynasty-hover { background: #FFF5DC !important; }
.timeline-hover .timeline-content { background: #FFF5DC !important; }
.figure-hover { background: #FFF5DC !important; }
.trivia-hover { background: #FFF5DC !important; }
.action-hover { background: rgba(139,37,0,.1) !important; }
.search-btn-hover { background: rgba(196,136,46,.5) !important; }
.close-hover { opacity: 0.7; }

/* 加载点 */
.loading-dots { display: flex; gap: 10rpx; }
.dot {
  width: 14rpx; height: 14rpx;
  background: #C4882E; border-radius: 50%;
  animation: dotBounce 1.4s infinite ease-in-out;
}
.dot:nth-child(1) { animation-delay: -.32s; }
.dot:nth-child(2) { animation-delay: -.16s; }
@keyframes dotBounce {
  0%,80%,100% { transform: scale(0); }
  40% { transform: scale(1); }
}
.safe-bottom { height: env(safe-area-inset-bottom); }
