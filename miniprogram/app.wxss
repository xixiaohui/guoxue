/**app.wxss - 国学AI助手全局样式**/

/* 导入字体相关 */
page {
  background: #FDF6E3;
  color: #2C1810;
  font-family: -apple-system, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #FDF6E3;
}

/* 卡片样式 */
.card {
  background: #FFFBF0;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 16rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(139, 37, 0, 0.08);
  border: 1rpx solid #EDD9A3;
}

/* 标题样式 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B2500;
  padding: 0 24rpx 16rpx;
  position: relative;
}

.section-title::before {
  content: '';
  display: inline-block;
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #C4882E, #8B2500);
  border-radius: 4rpx;
  margin-right: 16rpx;
  vertical-align: middle;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #C4882E, #8B2500);
  color: #FDF6E3;
  border: none;
  border-radius: 48rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(139, 37, 0, 0.3);
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-outline {
  background: transparent;
  color: #8B2500;
  border: 2rpx solid #C4882E;
  border-radius: 48rpx;
  padding: 18rpx 48rpx;
  font-size: 28rpx;
}

/* 标签样式 */
.tag {
  display: inline-block;
  background: #FFF3DC;
  color: #8B2500;
  border: 1rpx solid #E8C88A;
  border-radius: 24rpx;
  padding: 6rpx 20rpx;
  font-size: 24rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #E8D5A3;
  margin: 20rpx 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: #8C7B61;
}

.empty-state text {
  font-size: 26rpx;
  margin-top: 20rpx;
  text-align: center;
  line-height: 1.8;
}

/* 加载动画 */
.loading-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #C4882E;
  border-radius: 50%;
  animation: dotBounce 1.4s infinite ease-in-out;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

/* 水墨风格装饰 */
.ink-decoration {
  color: rgba(139, 37, 0, 0.12);
  font-size: 120rpx;
  font-weight: bold;
  position: absolute;
  right: 20rpx;
  top: 0;
  line-height: 1;
  pointer-events: none;
}

/* 纹理背景 */
.texture-bg {
  background-image: repeating-linear-gradient(
    45deg,
    transparent,
    transparent 20px,
    rgba(196, 136, 46, 0.03) 20px,
    rgba(196, 136, 46, 0.03) 21px
  );
}

/* 古典边框 */
.classic-border {
  border: 2rpx solid #C4882E;
  border-radius: 8rpx;
  position: relative;
}

.classic-border::before,
.classic-border::after {
  content: '◆';
  position: absolute;
  color: #C4882E;
  font-size: 20rpx;
}

.classic-border::before {
  top: -12rpx;
  left: 50%;
  transform: translateX(-50%);
}

.classic-border::after {
  bottom: -12rpx;
  left: 50%;
  transform: translateX(-50%);
}

/* 滚动区域 */
.scroll-area {
  flex: 1;
  overflow-y: auto;
}

/* 底部安全区 */
.safe-bottom {
  height: env(safe-area-inset-bottom);
  height: constant(safe-area-inset-bottom);
}

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.4s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* 文字渐变 */
.gradient-text {
  background: linear-gradient(135deg, #C4882E, #8B2500);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
